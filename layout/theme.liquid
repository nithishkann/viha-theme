<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0F5A43">

  <title>{{- page_title -}}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {%- comment -%} `!= blank`, not truthiness — an empty string is truthy in Liquid,
      which emitted <meta name="description" content=""> on description-less pages. {%- endcomment -%}
  {% if page_description != blank %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {%- comment -%} Canonical & hreflang {%- endcomment -%}
  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} Favicon {%- endcomment -%}
  {% if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | img_url: '32x32' }}">
  {% endif %}

  {%- comment -%} Open Graph / Twitter Card — resolve the best available image once.
    Chain: page's own image → configured default share image → shop logo, so
    pages without their own image (homepage, custom pages) still get a preview
    (matters for WhatsApp/Carthike link previews). {%- endcomment -%}
  {%- assign social_image = page_image | default: settings.social_share_image | default: settings.logo -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:type" content="{% if template contains 'product' %}product{% else %}website{% endif %}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if social_image != blank -%}
    <meta property="og:image" content="https:{{ social_image | img_url: '1200x630' }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
  {%- else -%}
    <meta name="twitter:card" content="summary">
  {%- endif -%}
  <meta name="twitter:title" content="{{ page_title | escape }}">
  {%- if page_description -%}
    <meta name="twitter:description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- comment -%} Prefer the real logo for schema imagery; favicon is a poor-quality
    fallback (Google uses this for the knowledge panel / local listing). {%- endcomment -%}
  {%- assign schema_logo = settings.logo | default: settings.favicon -%}

  {%- comment -%} Global structured data — Organization + WebSite/SearchAction {%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }}
      {%- if schema_logo != blank -%},"logo": {{ schema_logo | image_url: width: 512 | prepend: 'https:' | json }}{%- endif -%}
      {%- assign social_links = '' -%}
      {%- if settings.social_instagram_link != blank -%}{%- assign social_links = social_links | append: settings.social_instagram_link | append: ',' -%}{%- endif -%}
      {%- if settings.social_facebook_link != blank -%}{%- assign social_links = social_links | append: settings.social_facebook_link | append: ',' -%}{%- endif -%}
      {%- if settings.social_youtube_link != blank -%}{%- assign social_links = social_links | append: settings.social_youtube_link | append: ',' -%}{%- endif -%}
      {%- if social_links != '' -%}
        ,"sameAs": {{ social_links | split: ',' | json }}
      {%- endif -%}
    }
  </script>
  {%- capture search_target -%}{{ shop.url }}{{ routes.search_url }}?q={search_term_string}{%- endcapture -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ search_target | json }},
        "query-input": "required name=search_term_string"
      }
    }
  </script>

  {%- comment -%} Global structured data — LocalBusiness (Chennai showroom) {%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Store",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }}
      {%- if schema_logo != blank -%},"image": {{ schema_logo | image_url: width: 512 | prepend: 'https:' | json }}{%- endif -%}
      {%- if settings.business_phone != blank -%},"telephone": {{ settings.business_phone | json }}{%- endif -%}
      ,"address": {
        "@type": "PostalAddress"
        {%- if settings.business_street_address != blank -%},"streetAddress": {{ settings.business_street_address | json }}{%- endif -%}
        {%- if settings.business_city != blank -%},"addressLocality": {{ settings.business_city | json }}{%- endif -%}
        {%- if settings.business_region != blank -%},"addressRegion": {{ settings.business_region | json }}{%- endif -%}
        {%- if settings.business_postal_code != blank -%},"postalCode": {{ settings.business_postal_code | json }}{%- endif -%}
        {%- if settings.business_country != blank -%},"addressCountry": {{ settings.business_country | json }}{%- endif -%}
      }
      {%- if settings.business_hours_days != blank and settings.business_hours_open != blank and settings.business_hours_close != blank -%}
        {%- capture opening_hours -%}{{ settings.business_hours_days }} {{ settings.business_hours_open }}-{{ settings.business_hours_close }}{%- endcapture -%}
        ,"openingHours": {{ opening_hours | json }}
      {%- endif -%}
    }
  </script>

  {%- comment -%} Preconnect for fonts {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

  {%- comment -%} Shopify required head content {%- endcomment -%}
  {{ content_for_header }}

  {%- comment -%} Theme fonts via Shopify font picker {%- endcomment -%}
  {%- assign font_heading = settings.font_heading | font_modify: 'weight', '700' -%}
  {%- assign font_body    = settings.font_body -%}
  <style>
    {{ font_heading | font_face: font_display: 'swap' }}
    {{ font_body    | font_face: font_display: 'swap' }}
    :root {
      --color-maroon:      {{ settings.color_maroon }};
      --color-maroon-dark: {{ settings.color_maroon_dark }};
      --color-gold:        {{ settings.color_gold }};
      --color-cream:       {{ settings.color_cream }};
      --color-cream-dark:  {{ settings.color_cream_dark }};
      --color-charcoal:    {{ settings.color_charcoal }};
      --font-heading:      {{ font_heading.family | json }}, Georgia, serif;
      --font-body:         {{ font_body.family    | json }}, system-ui, sans-serif;
    }
  </style>

  {%- comment -%} Theme stylesheet {%- endcomment -%}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name }}{% if template.suffix != blank %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- comment -%} Accessibility skip link {%- endcomment -%}
  <a href="#main-content" class="sr-only" style="position:absolute;top:1rem;left:1rem;padding:0.75rem 1.25rem;background:var(--color-maroon);color:#fff;font-weight:700;z-index:9999;text-decoration:none;border-radius:2px;transform:translateY(-200%);transition:transform 0.2s;" onfocus="this.style.transform='translateY(0)'" onblur="this.style.transform='translateY(-200%)'">
    Skip to content
  </a>

  {%- comment -%} ── Announcement Bar ──────────────────────────────────── {%- endcomment -%}
  {% section 'announcement-bar' %}

  {%- comment -%} ── Header ────────────────────────────────────────────── {%- endcomment -%}
  {% section 'header' %}

  {%- comment -%} ── Mobile Menu Overlay ───────────────────────────────── {%- endcomment -%}
  {% render 'mobile-menu' %}

  {%- comment -%} ── Main Content ──────────────────────────────────────── {%- endcomment -%}
  <main id="main-content" tabindex="-1" style="min-height:60vh;">
    {{ content_for_layout }}
  </main>

  {%- comment -%} ── Footer ────────────────────────────────────────────── {%- endcomment -%}
  {% section 'footer' %}

  {%- comment -%} ── Delivery notice popup (site-wide, once per session) ── {%- endcomment -%}
  {% section 'delivery-notice' %}

  {%- comment -%} ── Mobile Bottom Nav ─────────────────────────────────── {%- endcomment -%}
  {% render 'mobile-bottom-nav' %}

  {%- comment -%} ── Cart Drawer ───────────────────────────────────────── {%- endcomment -%}
  {% if settings.cart_type == 'drawer' %}
    {% render 'cart-drawer' %}
  {% endif %}

  {%- comment -%} ── Search Overlay ────────────────────────────────────── {%- endcomment -%}
  {% render 'search-overlay' %}

  {%- comment -%} ── Theme JS ──────────────────────────────────────────── {%- endcomment -%}
  <script>window.theme = window.theme || {}; window.theme.moneyFormat = {{ shop.money_format | json }};</script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  {%- comment -%} ── Shopify analytics / required scripts ──────────────── {%- endcomment -%}
  {{ content_for_additional_checkout_buttons }}
</body>
</html>
