{%- comment -%} Our Story page — closing CTA {%- endcomment -%}
<section style="background:var(--color-cream);padding:4rem 1.5rem;text-align:center;">
  <h2 style="font-family:var(--font-heading);font-size:clamp(1.5rem,4vw,2rem);font-weight:900;color:var(--color-maroon);margin-bottom:0.75rem;">{{ section.settings.heading | default: 'Begin Your Sacred Journey' }}</h2>
  <p style="font-size:14px;color:rgba(45,45,45,0.65);margin-bottom:2rem;max-width:420px;margin-left:auto;margin-right:auto;line-height:1.7;">{{ section.settings.subtext | default: 'Explore our carefully curated collection of authentic spiritual essentials, Ayurvedic wellness products and handcrafted jewellery.' }}</p>
  <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn--primary" style="display:inline-flex;align-items:center;gap:8px;">
    {{ section.settings.button_label | default: 'Shop All Essentials' }}
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
  </a>
</section>

{% schema %}
{
  "name": "Story CTA",
  "settings": [
    { "type": "text",     "id": "heading",       "label": "Heading",      "default": "Begin Your Sacred Journey" },
    { "type": "textarea", "id": "subtext",       "label": "Subtext" },
    { "type": "text",     "id": "button_label",  "label": "Button label", "default": "Shop All Essentials" },
    { "type": "url",      "id": "button_url",    "label": "Button link" }
  ],
  "presets": [{ "name": "Story CTA" }]
}
{% endschema %}
