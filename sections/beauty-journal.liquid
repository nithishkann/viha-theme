{%- comment -%} Beauty page "Beauty Journal" — blog picker instead of hardcoded 'beauty' blog handle {%- endcomment -%}
{%- assign beauty_blog = section.settings.blog | default: blogs['beauty'] -%}
<section id="beauty-journal" style="padding:4rem 3rem;background:var(--color-cream);border-top:1px solid var(--color-cream-dark);">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem;">
      <div>
        <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Education & Ritual' }}</span>
        <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,2rem);font-weight:900;color:var(--color-maroon);">{{ section.settings.heading | default: 'Beauty Journal' }}</h2>
      </div>
      {%- if beauty_blog != blank -%}
        <a href="{{ beauty_blog.url }}" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:var(--color-maroon);transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-maroon)'">
          All Articles
          <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- if beauty_blog != blank and beauty_blog.articles_count > 0 -%}
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
        {%- for article in beauty_blog.articles limit: section.settings.posts_to_show -%}
          <article style="border:1px solid var(--color-cream-dark);border-top:2px solid transparent;border-radius:2px;overflow:hidden;background:var(--color-paper);transition:box-shadow 0.2s,border-top-color 0.2s;" onmouseover="this.style.boxShadow='0 6px 20px rgba(0,0,0,0.09)';this.style.borderTopColor='var(--color-gold)'" onmouseout="this.style.boxShadow='';this.style.borderTopColor='transparent'">
            {%- if article.image -%}
              <a href="{{ article.url }}" style="display:block;aspect-ratio:3/2;overflow:hidden;" aria-hidden="true">
                <img src="{{ article.image | img_url: '600x' }}" alt="{{ article.image.alt | default: article.title | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform=''">
              </a>
            {%- endif -%}
            <div style="padding:1.5rem;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
                {%- for tag in article.tags limit: 1 -%}
                  <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-gold);background:rgba(184,137,61,0.10);border:1px solid rgba(184,137,61,0.20);padding:2px 7px;border-radius:2px;">{{ tag }}</span>
                {%- endfor -%}
              </div>
              <h3 style="font-family:var(--font-heading);font-size:1rem;font-weight:700;color:var(--color-maroon);margin-bottom:0.5rem;line-height:1.3;"><a href="{{ article.url }}" style="color:inherit;">{{ article.title }}</a></h3>
              {%- if article.excerpt -%}
                <p style="font-size:12px;color:rgba(45,45,45,0.65);line-height:1.65;margin-bottom:1rem;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{{ article.excerpt | strip_html }}</p>
              {%- endif -%}
              <a href="{{ article.url }}" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-maroon);display:inline-flex;align-items:center;gap:5px;transition:gap 0.15s;" onmouseover="this.style.gap='9px'" onmouseout="this.style.gap='5px'">
                Read Article <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center;color:var(--color-muted);font-size:13px;padding:2rem 0;">{{ section.settings.empty_message | default: 'Our Beauty Journal is launching soon — check back for Ayurvedic rituals and skincare wisdom from Mrs Anitha Kuppusamy.' }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Beauty Journal",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Education & Ritual" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beauty Journal" },
    { "type": "blog", "id": "blog", "label": "Blog to display", "info": "Defaults to the \"beauty\" blog if left blank" },
    { "type": "range", "id": "posts_to_show", "label": "Posts to show", "min": 2, "max": 6, "step": 1, "default": 3 },
    { "type": "textarea", "id": "empty_message", "label": "Message shown when the blog has no posts yet" }
  ],
  "presets": [{ "name": "Beauty Journal" }]
}
{% endschema %}
