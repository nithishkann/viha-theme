{%- comment -%} Beauty page testimonials — each review is a block, editable so real reviews can replace the placeholders {%- endcomment -%}
<section style="padding:4rem 3rem;background:var(--color-section-alt);border-top:1px solid var(--color-cream-dark);">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Real Results' }}</span>
      <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,2rem);font-weight:900;color:var(--color-maroon);">{{ section.settings.heading | default: 'What Our Customers Say' }}</h2>
      <div class="section__ornament" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1rem;">
        <div class="section__ornament-line section__ornament-line--left"></div>
        <div class="section__ornament-diamond"></div>
        <div class="section__ornament-line section__ornament-line--right"></div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
      {%- for block in section.blocks -%}
        <div style="border:1px solid var(--color-cream-dark);border-radius:2px;background:var(--color-paper);padding:1.75rem;display:flex;flex-direction:column;gap:1rem;transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.08)'" onmouseout="this.style.boxShadow=''" {{ block.shopify_attributes }}>
          <div style="display:flex;gap:2px;" aria-label="{{ block.settings.rating }} stars">
            {%- for i in (1..5) -%}
              <svg width="13" height="13" fill="currentColor" viewBox="0 0 20 20" style="color:{% if i <= block.settings.rating %}var(--color-gold){% else %}var(--color-cream-dark){% endif %};" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            {%- endfor -%}
          </div>
          <blockquote style="font-size:13px;color:rgba(45,45,45,0.82);line-height:1.75;font-style:italic;border-left:2px solid var(--color-gold);padding-left:1rem;flex:1;">&ldquo;{{ block.settings.quote }}&rdquo;</blockquote>
          <div style="border-top:1px solid var(--color-cream-dark);padding-top:1rem;display:flex;align-items:center;gap:10px;">
            <div style="width:36px;height:36px;border-radius:50%;background:var(--color-maroon);color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--font-heading);font-weight:700;font-size:15px;flex-shrink:0;" aria-hidden="true">{{ block.settings.name | slice: 0 }}</div>
            <div>
              <div style="font-size:12px;font-weight:700;color:var(--color-charcoal);">{{ block.settings.name }}</div>
              <div style="font-size:11px;color:rgba(45,45,45,0.50);margin-top:1px;">{{ block.settings.location }} &mdash; {{ block.settings.product }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beauty Reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Real Results" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Review quote" },
        { "type": "text", "id": "name", "label": "Customer name" },
        { "type": "text", "id": "location", "label": "Customer location" },
        { "type": "text", "id": "product", "label": "Product purchased" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beauty Reviews",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "name": "Priya Venkataraman", "location": "Chennai", "product": "Handmade Red Sandalwood Soap", "quote": "The sandalwood soap is pure luxury. The fragrance lingers gently and my skin feels smooth without feeling stripped. I've ordered four bars now." } },
        { "type": "review", "settings": { "rating": 5, "name": "Meera Krishnamurthy", "location": "Bengaluru", "product": "Heritage Vetiver Bath Scrub", "quote": "This scrub is the real thing — I've tried so many branded versions and nothing compares. The earthy vetiver scent is completely grounding." } },
        { "type": "review", "settings": { "rating": 5, "name": "Ananya Subramaniam", "location": "Mumbai", "product": "Divine Jasmine Attar", "quote": "Alcohol-free and long-lasting — it smells exactly like fresh jasmine garlands. Not sweet and not artificial. This is what attar should be." } }
      ]
    }
  ]
}
{% endschema %}
