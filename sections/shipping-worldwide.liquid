{%- comment -%}
  Shipping worldwide — international shipping information strip.
  Upgrade of the old Debut homepage text block; every line is an editable block.
{%- endcomment -%}

<section class="ship-info">
  <div class="ship-info__inner">
    <span class="ship-info__eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="ship-info__title">{{ section.settings.heading }}</h2>
    <span class="ship-info__rule" aria-hidden="true"></span>
    {%- if section.settings.intro != blank -%}
      <p class="ship-info__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    <div class="ship-info__rows">
      {%- for block in section.blocks -%}
        <div class="ship-info__row{% if block.settings.highlight %} ship-info__row--note{% endif %}" {{ block.shopify_attributes }}>
          <span class="ship-info__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'globe' -%}
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18zM3.6 9h16.8M3.6 15h16.8M12 3a13.5 13.5 0 000 18M12 3a13.5 13.5 0 010 18"/></svg>
              {%- when 'alert' -%}
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
              {%- when 'clock' -%}
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              {%- else -%}
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
            {%- endcase -%}
          </span>
          <div class="ship-info__text rte">{{ block.settings.text }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.ship-info { background: var(--color-cream, #FDF9F1); padding: 4rem 1.5rem; text-align: center; }
.ship-info__inner { max-width: 720px; margin: 0 auto; }
.ship-info__eyebrow { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.22em; color: var(--color-gold); margin-bottom: 6px; }
.ship-info__title { font-family: var(--font-heading); font-size: clamp(24px, 4vw, 34px); color: var(--color-maroon); margin: 0 0 0.75rem; }
.ship-info__rule { display: inline-block; width: 56px; height: 2px; background: var(--color-gold); margin-bottom: 1rem; }
.ship-info__intro { font-size: 14px; line-height: 1.75; color: rgba(45,45,45,0.75); margin: 0 0 2rem; }
.ship-info__rows { display: flex; flex-direction: column; gap: 12px; text-align: left; }
.ship-info__row { display: flex; gap: 14px; align-items: flex-start; background: #fff; border: 1px solid var(--color-cream-dark, #E5DED1); border-radius: 3px; padding: 1.1rem 1.25rem; }
.ship-info__row--note { border-left: 3px solid var(--color-gold); background: #FBF6EC; }
.ship-info__icon { flex-shrink: 0; color: var(--color-maroon); margin-top: 2px; }
.ship-info__text { font-size: 13.5px; line-height: 1.75; color: var(--color-charcoal); }
.ship-info__text p { margin: 0; }
.ship-info__text strong { color: var(--color-maroon); }
@media (max-width: 767px) { .ship-info { padding: 3rem 1.25rem; } }
</style>

{% schema %}
{
  "name": "Shipping worldwide",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From Chennai to Your Doorstep" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shipping Worldwide" },
    { "type": "text", "id": "intro", "label": "Intro line", "default": "We deliver Viha products across India and around the world." }
  ],
  "blocks": [
    {
      "type": "line",
      "name": "Info line",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "globe", "label": "Globe" },
            { "value": "alert", "label": "Alert" },
            { "value": "clock", "label": "Clock" },
            { "value": "truck", "label": "Truck" }
          ],
          "default": "globe"
        },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>International shipping at low costs.</p>" },
        { "type": "checkbox", "id": "highlight", "label": "Highlight (gold accent)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shipping worldwide",
      "blocks": [
        { "type": "line", "settings": { "icon": "globe", "text": "<p>International shipping at low costs — duties and rates calculated at checkout. International payments are processed securely through Razorpay.</p>" } },
        { "type": "line", "settings": { "icon": "alert", "highlight": true, "text": "<p><strong>NOTE:</strong> Kindly avoid ordering Pachai Karpooram (edible camphor) &amp; Sangu (conch shell) for international shipments, and Shea Butter for UAE shipments — these are restricted by customs.</p>" } },
        { "type": "line", "settings": { "icon": "clock", "text": "<p>Minimum 14 working days required for international delivery. Day of booking, Sundays, public holidays and Tamil Nadu festival days are not working days.</p>" } }
      ]
    }
  ]
}
{% endschema %}
