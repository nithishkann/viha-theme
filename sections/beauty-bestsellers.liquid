{%- comment -%} Beauty page bestsellers grid — collection picker instead of hardcoded handle {%- endcomment -%}
{%- assign beauty_col = section.settings.collection -%}
<section style="padding:4rem 3rem;background:var(--color-cream);border-top:1px solid var(--color-cream-dark);">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem;">
      <div>
        <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Most Loved' }}</span>
        <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,2rem);font-weight:900;color:var(--color-maroon);">{{ section.settings.heading | default: 'Beauty Best Sellers' }}</h2>
      </div>
      {%- if beauty_col != blank -%}
        <a href="{{ beauty_col.url }}" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:var(--color-maroon);transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-maroon)'">
          View All
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- if beauty_col != blank and beauty_col.products.size > 0 -%}
      <div class="collection-grid">
        {%- for product in beauty_col.products limit: section.settings.products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="{{ beauty_col.url }}" class="btn btn--outline-maroon" style="display:inline-flex;align-items:center;gap:8px;padding:12px 28px;font-size:11px;">
          View All Beauty Products
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    {%- else -%}
      <p style="text-align:center;color:var(--color-muted);font-size:14px;">No products found. Choose a collection with products in the section settings.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Beauty Bestsellers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Most Loved" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beauty Best Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 8 }
  ],
  "presets": [{ "name": "Beauty Bestsellers" }]
}
{% endschema %}
