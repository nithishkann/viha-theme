{%- comment -%}
  FAQ page — each Q&A is a block with a "Group" label. Consecutive blocks sharing
  the same group render under one heading; changing the group starts a new one.
{%- endcomment -%}
<section style="background:var(--color-paper);padding:3.5rem 1.5rem 2rem;">
  <div style="max-width:800px;margin:0 auto;text-align:center;">
    <p style="font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Need Help?' }}</p>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3rem);font-weight:900;color:var(--color-maroon);line-height:1.1;margin-bottom:0.75rem;">{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h1>
    <p style="font-size:14px;color:rgba(45,45,45,0.65);line-height:1.75;">{{ section.settings.subtext | default: "Answers to common questions about orders, shipping, returns, and our products. Can't find what you're looking for?" }} <a href="/pages/contact" style="color:var(--color-maroon);text-decoration:underline;">Contact us</a>.</p>
  </div>
</section>

<div style="background:var(--color-paper);padding:1rem 1.5rem 5rem;">
  <div style="max-width:800px;margin:0 auto;">

    {%- assign previous_group = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq_item' -%}
        {%- if block.settings.group != previous_group -%}
          {%- unless forloop.first -%}</div>{%- endunless -%}
          <div style="margin-top:2.5rem;">
            <h2 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:900;color:var(--color-maroon);padding-bottom:0.75rem;border-bottom:1px solid var(--color-cream-dark);margin-bottom:0.5rem;">{{ block.settings.group }}</h2>
          {%- assign previous_group = block.settings.group -%}
        {%- endif -%}
        <details style="border-bottom:1px solid var(--color-cream-dark);padding:1rem 0;" {{ block.shopify_attributes }}>
          <summary style="cursor:pointer;list-style:none;font-size:14px;font-weight:700;color:var(--color-charcoal);display:flex;align-items:center;justify-content:space-between;gap:1rem;">
            {{ block.settings.question }}
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:var(--color-gold);" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p style="font-size:13px;color:rgba(45,45,45,0.68);line-height:1.75;margin-top:0.75rem;">{{ block.settings.answer }}</p>
        </details>
        {%- if forloop.last -%}</div>{%- endif -%}
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

<style>
details > summary { outline: none; }
details > summary::-webkit-details-marker { display: none; }
details[open] summary svg { transform: rotate(180deg); }
details summary svg { transition: transform 0.2s; }
</style>

{% schema %}
{
  "name": "FAQ Page",
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow text", "default": "Need Help?" },
    { "type": "text",     "id": "heading",  "label": "Heading",      "default": "Frequently Asked Questions" },
    { "type": "textarea", "id": "subtext",  "label": "Subtext" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        { "type": "text",     "id": "group",    "label": "Group heading", "info": "Questions with the same group heading are shown together", "default": "Orders & Shipping" },
        { "type": "text",     "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer",   "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page",
      "blocks": [
        { "type": "faq_item", "settings": { "group": "Orders & Shipping", "question": "How long does shipping take?", "answer": "We ship across India within 5–7 business days and internationally within 10–15 business days, depending on destination customs processing." } },
        { "type": "faq_item", "settings": { "group": "Orders & Shipping", "question": "Do you ship internationally?", "answer": "Yes — we currently ship to 6 countries including the US, UK, Canada, Australia, Singapore, and the UAE. Shipping is free on orders over ₹999 (or the equivalent in your local currency)." } },
        { "type": "faq_item", "settings": { "group": "Orders & Shipping", "question": "How can I track my order?", "answer": "Once your order ships, you'll receive a tracking link by email. You can also check status anytime on our Track Order page using your order ID." } },
        { "type": "faq_item", "settings": { "group": "Returns & Refunds", "question": "What is your return policy?", "answer": "We accept returns within 7 days of delivery for unused, unopened items in original packaging. See our full Returns & Refunds policy for details." } },
        { "type": "faq_item", "settings": { "group": "Returns & Refunds", "question": "How do I request a refund?", "answer": "Contact us with your order number and reason for return. Once we receive and inspect the item, refunds are processed within 5–7 business days to your original payment method." } },
        { "type": "faq_item", "settings": { "group": "Returns & Refunds", "question": "Are sacred/pooja items returnable?", "answer": "For hygiene and ritual-use reasons, opened consumables, idols that have been consecrated, and personal-use Ayurvedic items are not eligible for return unless defective." } },
        { "type": "faq_item", "settings": { "group": "Products & Authenticity", "question": "Are your products genuinely handcrafted?", "answer": "Yes. Every item is sourced directly from verified traditional artisans across Tamil Nadu and India, personally vetted by our founder Mrs Anitha Kuppusamy." } },
        { "type": "faq_item", "settings": { "group": "Products & Authenticity", "question": "Are your Ayurvedic products certified?", "answer": "Our Ayurvedic and herbal products use pure, traditionally-sourced ingredients. Certification details are listed on individual product pages where applicable." } },
        { "type": "faq_item", "settings": { "group": "Products & Authenticity", "question": "Can I get help choosing the right product?", "answer": "Absolutely — reach out via WhatsApp or our Contact page and our team will help you choose based on your ritual, gifting, or wellness needs." } }
      ]
    }
  ]
}
{% endschema %}
