{%- comment -%}
  Store banner — full-width store photo with an overlaid card:
  heading, address, Get Directions link. Fully client-editable.
{%- endcomment -%}

{%- assign map_link = section.settings.map_url | default: 'https://maps.app.goo.gl/4EASzgQfbGdXkLR57' -%}

<section class="store-banner">
  {%- if section.settings.image -%}
    <img
      class="store-banner__bg"
      src="{{ section.settings.image | image_url: width: 1800 }}"
      srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 1800 }} 1800w"
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: 'Inside the Viha store' | escape }}"
      width="1800" height="{{ 1800 | divided_by: section.settings.image.aspect_ratio | round | default: 900 }}"
      loading="lazy"
    >
  {%- else -%}
    <div class="store-banner__bg store-banner__bg--placeholder" aria-hidden="true"></div>
  {%- endif -%}
  <div class="store-banner__scrim" aria-hidden="true"></div>

  <div class="store-banner__card">
    <span class="store-banner__eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="store-banner__title">{{ section.settings.heading }}</h2>
    <span class="store-banner__rule" aria-hidden="true"></span>
    <div class="store-banner__address rte">{{ section.settings.address }}</div>
    <a class="btn btn--primary store-banner__btn" href="{{ map_link }}" target="_blank" rel="noopener">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true" style="margin-right:7px;flex-shrink:0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
      </svg>
      {{ section.settings.button_label }}
    </a>
  </div>
</section>

<style>
.store-banner { position: relative; min-height: 480px; display: flex; align-items: center; justify-content: flex-start; padding: 4rem clamp(1.5rem, 6vw, 5rem); overflow: hidden; }
.store-banner__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.store-banner__bg--placeholder { background: linear-gradient(135deg, var(--color-maroon-dark) 0%, var(--color-maroon) 60%, #14684f 100%); }
.store-banner__scrim { position: absolute; inset: 0; background: rgba(15, 25, 20, 0.35); }
.store-banner__card { position: relative; background: #fff; max-width: 480px; width: 100%; padding: 2.5rem 2rem; text-align: left; border-radius: 3px; border-top: 3px solid var(--color-gold); box-shadow: 0 18px 50px rgba(0,0,0,0.25); }
.store-banner__eyebrow { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.22em; color: var(--color-gold); margin-bottom: 6px; }
.store-banner__title { font-family: var(--font-heading); font-size: clamp(22px, 3.5vw, 30px); color: var(--color-maroon); margin: 0 0 0.75rem; }
.store-banner__rule { display: inline-block; width: 48px; height: 2px; background: var(--color-gold); margin-bottom: 1rem; }
.store-banner__address { font-size: 14px; line-height: 1.85; color: var(--color-charcoal); margin-bottom: 1.5rem; }
.store-banner__address p { margin: 0 0 0.5rem; }
.store-banner__btn { width: auto; min-height: 46px; padding: 0 1.5rem; display: inline-flex; align-items: center; justify-content: center; }
@media (max-width: 767px) { .store-banner { min-height: 420px; padding: 3rem 1.25rem; } .store-banner__card { padding: 2rem 1.5rem; } }
</style>

{% schema %}
{
  "name": "Store banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Store photo", "info": "Wide photo of the showroom. A brand-colour background shows until one is picked." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Visit Us in Chennai" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Store" },
    {
      "type": "richtext",
      "id": "address",
      "label": "Address",
      "default": "<p>VIHA, No 10, Bhagirathy Street, Raja Annamalaipuram, Chennai 600028</p><p>(Near Kamakshi Amman Temple)</p>"
    },
    { "type": "url", "id": "map_url", "label": "Google Maps link", "info": "Leave empty to use the default Viha showroom map link" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get Directions" }
  ],
  "presets": [{ "name": "Store banner" }]
}
{% endschema %}
