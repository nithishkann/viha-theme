{%- comment -%} Mega-menu "featured" tile pulls the latest post from the "news" blog (same article in every panel) {%- endcomment -%}
{%- assign mega_blog_article = blogs['news'].articles.first -%}
{%- assign mega_blog_img = mega_blog_article.image | img_url: '100x100' -%}
{%- assign mega_blog_date = mega_blog_article.published_at | date: '%b %d, %Y' -%}
{%- assign mega_blog_excerpt = mega_blog_article.excerpt | strip_html | strip_newlines -%}
{%- if mega_blog_excerpt == blank -%}
  {%- assign mega_blog_excerpt = mega_blog_article.content | strip_html | strip_newlines | truncate: 100 -%}
{%- endif -%}

{%- comment -%} Beauty & Wellness panel only shows posts tagged "beauty"; falls back to the general latest post if none are tagged yet {%- endcomment -%}
{%- assign beauty_blog_article = blogs['news'].articles | where: 'tags', 'beauty' | first -%}
{%- if beauty_blog_article == blank -%}
  {%- assign beauty_blog_article = mega_blog_article -%}
{%- endif -%}
{%- assign beauty_blog_img = beauty_blog_article.image | img_url: '100x100' -%}
{%- assign beauty_blog_date = beauty_blog_article.published_at | date: '%b %d, %Y' -%}
{%- assign beauty_blog_excerpt = beauty_blog_article.excerpt | strip_html | strip_newlines -%}
{%- if beauty_blog_excerpt == blank -%}
  {%- assign beauty_blog_excerpt = beauty_blog_article.content | strip_html | strip_newlines | truncate: 100 -%}
{%- endif -%}

<header class="site-header" role="banner">

  {%- comment -%} ── Row 1: Logo + Tagline + Utility Icons ─────────────── {%- endcomment -%}
  <div class="header__row-1">

    {%- comment -%} Mobile hamburger (left) {%- endcomment -%}
    <button class="header__icon-btn lg:hidden" data-mobile-menu-open aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"/>
      </svg>
    </button>

    {%- comment -%} Logo {%- endcomment -%}
    <a href="/" class="header__logo" aria-label="{{ shop.name }} — Home">
      {% if settings.logo != blank %}
        {%- comment -%} Height via custom property (not inline height) so the
          mobile media query in theme.css can still shrink the logo. {%- endcomment -%}
        <img
          src="{{ settings.logo | img_url: 'medium' }}"
          alt="{{ shop.name }}"
          height="{{ settings.logo_height }}"
          style="--logo-h:{{ settings.logo_height | default: 70 }}px;"
          loading="eager"
          fetchpriority="high"
        >
      {% else %}
        <span class="header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    {%- comment -%} Centre tagline (desktop only) {%- endcomment -%}
    <div class="header__tagline" aria-hidden="true">
      <span class="header__tagline-brand">Viha Heritage Store</span>
      <span class="header__tagline-sub">Spiritual Essentials Curated by Mrs Anitha Kuppusamy</span>
    </div>

    {%- comment -%} Right icon group {%- endcomment -%}
    <div class="header__icons">

      {%- comment -%} Country / currency — read-only display; change it from Account → Region & Currency {%- endcomment -%}
      {%- comment -%} aria-label is prohibited on a plain span (Lighthouse aria-prohibited-attr);
          use visually-hidden text instead. {%- endcomment -%}
      <span class="country-badge">
        <span class="sr-only">Shopping from {{ localization.country.name }}, currency {{ localization.country.currency.iso_code }}</span>
        <span aria-hidden="true">{% render 'flag-emoji', code: localization.country.iso_code %}</span>
        <span class="hidden md:inline" aria-hidden="true">{{ localization.country.currency.iso_code }}</span>
      </span>

      {%- comment -%} Search {%- endcomment -%}
      <button class="header__icon-btn" data-search-open aria-label="Search products">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z"/>
        </svg>
      </button>

      {%- comment -%} Account (routes object resolves to Shopify's hosted account UI) {%- endcomment -%}
      {%- if customer -%}
        <a href="{{ routes.account_url }}" class="header__icon-btn header__icon-btn--desktop" aria-label="My account">
      {%- else -%}
        <a href="{{ routes.account_login_url }}" class="header__icon-btn header__icon-btn--desktop" aria-label="Sign in">
      {%- endif -%}
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
        </svg>
      </a>

      {%- comment -%} Wishlist {%- endcomment -%}
      <a href="/pages/wishlist" class="header__icon-btn" aria-label="Wishlist">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
        </svg>
      </a>

      {%- comment -%} Cart {%- endcomment -%}
      {% if settings.cart_type == 'drawer' %}
        <button class="header__icon-btn" data-cart-open aria-label="Open cart ({{ cart.item_count }} items)" aria-expanded="false">
      {% else %}
        <a href="/cart" class="header__icon-btn" aria-label="Cart ({{ cart.item_count }} items)">
      {% endif %}
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/>
          </svg>
          <span class="header__badge header__badge--maroon" data-cart-badge aria-live="polite" {% if cart.item_count == 0 %}style="display:none;"{% endif %}>{{ cart.item_count }}</span>
      {% if settings.cart_type == 'drawer' %}
        </button>
      {% else %}
        </a>
      {% endif %}

    </div>{%- comment -%} /.header__icons {%- endcomment -%}
  </div>{%- comment -%} /.header__row-1 {%- endcomment -%}

