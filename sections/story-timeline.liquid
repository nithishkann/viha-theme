{%- comment -%} Our Story page — heritage timeline, each milestone a block {%- endcomment -%}
<section style="background:var(--color-paper);padding:5rem 1.5rem;">
  <div style="max-width:700px;margin:0 auto;text-align:center;">
    <p style="font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Our Journey' }}</p>
    <h2 style="font-family:var(--font-heading);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:var(--color-maroon);margin-bottom:3rem;">{{ section.settings.heading | default: 'Milestones of Devotion' }}</h2>
    <div style="position:relative;padding-left:2rem;border-left:2px solid var(--color-cream-dark);text-align:left;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'milestone' -%}
          <div style="position:relative;margin-bottom:2.5rem;padding-left:1.5rem;" {{ block.shopify_attributes }}>
            <div style="position:absolute;left:-2.5rem;top:4px;width:16px;height:16px;border-radius:50%;background:var(--color-maroon);border:3px solid var(--color-paper);box-shadow:0 0 0 2px var(--color-gold);"></div>
            <p style="font-size:10px;font-weight:700;letter-spacing:0.16em;color:var(--color-gold);text-transform:uppercase;margin-bottom:0.375rem;">{{ block.settings.year }}</p>
            <p style="font-size:14px;color:rgba(45,45,45,0.75);line-height:1.75;">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story Timeline",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Our Journey" },
    { "type": "text", "id": "heading", "label": "Heading",      "default": "Milestones of Devotion" }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        { "type": "text",     "id": "year",        "label": "Year / Label", "default": "2010" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Timeline",
      "blocks": [
        { "type": "milestone", "settings": { "year": "2010", "description": "Founded in Chennai, Tamil Nadu — Mrs. Anitha Kuppusamy begins curating sacred essentials from traditional artisans." } },
        { "type": "milestone", "settings": { "year": "2015", "description": "Expanded to international shipping — serving the Indian diaspora across USA, UK, Canada and UAE." } },
        { "type": "milestone", "settings": { "year": "2020", "description": "Crossed 50,000+ happy customers — trust built through authentic products and devotion to quality." } },
        { "type": "milestone", "settings": { "year": "2023", "description": "Ships to 6 countries — delivering sacred traditions to devotees worldwide, every single day." } }
      ]
    }
  ]
}
{% endschema %}
