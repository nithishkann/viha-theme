{%- comment -%} Beauty page 4-step ritual — each step is a block {%- endcomment -%}
<section style="padding:5rem 3rem;background:var(--color-maroon);border-top:1px solid rgba(255,255,255,0.08);position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;opacity:0.06;background-image:radial-gradient(circle,#B8893D 1px,transparent 1px);background-size:20px 20px;pointer-events:none;"></div>
  <div style="max-width:var(--max-w);margin:0 auto;position:relative;z-index:1;">
    <div style="text-align:center;margin-bottom:3.5rem;">
      <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: '4-Step Practice' }}</span>
      <h2 style="font-family:var(--font-heading);font-size:clamp(1.5rem,3.5vw,2.25rem);font-weight:900;color:#fff;">{{ section.settings.heading | default: 'The Traditional Beauty Ritual' }}</h2>
      <div style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1rem;">
        <div style="height:1px;width:40px;background:linear-gradient(to right,transparent,rgba(184,137,61,0.5));"></div>
        <div style="width:6px;height:6px;background:rgba(184,137,61,0.75);transform:rotate(45deg);flex-shrink:0;"></div>
        <div style="height:1px;width:40px;background:linear-gradient(to left,transparent,rgba(184,137,61,0.5));"></div>
      </div>
      <p style="margin-top:1.5rem;font-size:12px;color:rgba(255,255,255,0.55);max-width:480px;margin-left:auto;margin-right:auto;line-height:1.75;">
        {{ section.settings.subtext | default: "Ayurvedic beauty is not a routine — it is a dialogue with your body. Each step responds to your skin's intelligence." }}
      </p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:2rem;">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:1rem;">
            <span style="font-family:var(--font-heading);font-size:3rem;font-weight:900;color:rgba(184,137,61,0.28);line-height:1;">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <div style="height:1px;flex:1;background:rgba(184,137,61,0.20);"></div>
          </div>
          <h3 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:700;color:#fff;margin-bottom:0.75rem;">{{ block.settings.title }}</h3>
          <p style="font-size:13px;color:rgba(255,255,255,0.60);line-height:1.75;">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
    <div style="text-align:center;margin-top:3.5rem;">
      <a href="{{ section.settings.cta_url | default: '/collections/ayurveda-herbal' }}" style="display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border:1px solid rgba(184,137,61,0.50);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.16em;color:var(--color-gold);transition:all 0.2s;" onmouseover="this.style.background='var(--color-gold)';this.style.color='#fff'" onmouseout="this.style.background='transparent';this.style.color='var(--color-gold)'">
        {{ section.settings.cta_label | default: 'Start Your Ritual' }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beauty Ritual Steps",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "4-Step Practice" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Traditional Beauty Ritual" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Start Your Ritual" },
    { "type": "url", "id": "cta_url", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Ritual step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Cleanse" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beauty Ritual Steps",
      "blocks": [
        { "type": "step", "settings": { "title": "Cleanse", "description": "Begin with a handmade herbal soap — neem, red sandalwood or tulsi. Let it draw impurities gently while preserving the skin's natural pH." } },
        { "type": "step", "settings": { "title": "Exfoliate", "description": "Use the vetiver root scrub or ubtan paste twice a week to slough dead cells and stimulate circulation, revealing fresh, bright skin." } },
        { "type": "step", "settings": { "title": "Nourish", "description": "Apply two to three drops of Kumkumadi oil or your chosen Ayurvedic facial blend. Press into warm skin — never rub." } },
        { "type": "step", "settings": { "title": "Seal", "description": "Finish with sandalwood or rose-based moisture cream to lock in actives. Fragrance becomes a closing breath of the ritual." } }
      ]
    }
  ]
}
{% endschema %}
