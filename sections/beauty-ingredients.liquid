{%- comment -%} Beauty page "Ingredient Spotlight" — each card is a block; image comes from its linked collection {%- endcomment -%}
<section style="padding:4rem 3rem;background:var(--color-paper);border-top:1px solid var(--color-cream-dark);">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Know Your Botanicals' }}</span>
      <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,2rem);font-weight:900;color:var(--color-maroon);">{{ section.settings.heading | default: 'Ingredient Spotlight' }}</h2>
      <div class="section__ornament" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1rem;">
        <div class="section__ornament-line section__ornament-line--left"></div>
        <div class="section__ornament-diamond"></div>
        <div class="section__ornament-line section__ornament-line--right"></div>
      </div>
      <p style="margin-top:1.25rem;font-size:12px;color:var(--color-muted);max-width:480px;margin-left:auto;margin-right:auto;line-height:1.75;">
        {{ section.settings.subtext | default: 'We trace every ingredient to its classical Ayurvedic text then to its source. This is not marketing — it is accountability.' }}
      </p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.25rem;">
      {%- for block in section.blocks -%}
        {%- assign ing_col = collections[block.settings.collection] -%}
        <div style="border:1px solid var(--color-cream-dark);border-radius:2px;overflow:hidden;background:var(--color-cream);transition:box-shadow 0.2s,border-color 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.09)';this.style.borderColor='rgba(15,90,67,0.3)'" onmouseout="this.style.boxShadow='';this.style.borderColor='var(--color-cream-dark)'" {{ block.shopify_attributes }}>
          <div style="aspect-ratio:4/3;overflow:hidden;background:var(--color-paper);">
            {%- if ing_col.image -%}
              <img src="{{ ing_col.image | img_url: '600x' }}" alt="{{ block.settings.title }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;filter:brightness(0.9);transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform=''">
            {%- else -%}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:rgba(15,90,67,0.20);">
                <svg width="30" height="30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18zM12 3v18M3 12h18"/></svg>
              </div>
            {%- endif -%}
          </div>
          <div style="padding:1rem;">
            <h3 style="font-family:var(--font-heading);font-size:14px;font-weight:700;color:var(--color-maroon);">{{ block.settings.title }}</h3>
            <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:var(--color-gold);margin:4px 0 6px;">{{ block.settings.tagline }}</p>
            <p style="font-size:12px;color:rgba(45,45,45,0.65);line-height:1.65;margin-bottom:0.75rem;">{{ block.settings.description }}</p>
            <a href="{{ ing_col.url | default: '#' }}" style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-maroon);display:inline-flex;align-items:center;gap:3px;transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-maroon)'">
              See Products
              <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredient Spotlight",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Know Your Botanicals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ingredient Spotlight" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient card",
      "settings": [
        { "type": "text", "id": "title", "label": "Ingredient name", "default": "Kumkumadi" },
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "Liquid Gold" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "collection", "id": "collection", "label": "Collection (also supplies the card image)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Spotlight",
      "blocks": [
        { "type": "ingredient", "settings": { "title": "Kumkumadi", "tagline": "Liquid Gold", "description": "Brightens complexion and reduces pigmentation with saffron and sesame base." } },
        { "type": "ingredient", "settings": { "title": "Neem", "tagline": "Nature's Antibiotic", "description": "Purifies skin and combats acne-causing bacteria while soothing redness and surface irritation." } },
        { "type": "ingredient", "settings": { "title": "Turmeric", "tagline": "Golden Healer", "description": "Anti-inflammatory powerhouse — reduces dark spots and evens tone while accelerating healing." } },
        { "type": "ingredient", "settings": { "title": "Red Sandalwood", "tagline": "Sacred Coolant", "description": "Cooling astringent and antibacterial — calms pitta and brings evenness to oily complexions." } },
        { "type": "ingredient", "settings": { "title": "Vetiver", "tagline": "Root of Calm", "description": "Detoxifying and cooling — exfoliates skin while delivering earthy aromatherapy and grounding energy." } }
      ]
    }
  ]
}
{% endschema %}
