{%- comment -%} Beauty page "Shop by Concern" — each card is a block: title, icon choice, collection {%- endcomment -%}
<section style="padding:5rem 3rem;background:var(--color-cream);">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div style="text-align:center;margin-bottom:3rem;">
      <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Personalised Care' }}</span>
      <h2 style="font-family:var(--font-heading);font-size:clamp(1.5rem,3vw,2.25rem);font-weight:900;color:var(--color-maroon);">{{ section.settings.heading | default: 'Shop by Concern' }}</h2>
      <div class="section__ornament" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1rem;">
        <div class="section__ornament-line section__ornament-line--left"></div>
        <div class="section__ornament-diamond"></div>
        <div class="section__ornament-line section__ornament-line--right"></div>
      </div>
    </div>

    <div class="concern-card-wrap" style="display:grid;gap:12px;">
      {%- for block in section.blocks -%}
        {%- assign concern_col = collections[block.settings.collection] -%}
        <a href="{{ concern_col.url | default: '#' }}" class="concern-card" style="display:flex;flex-direction:column;align-items:center;gap:12px;padding:1.25rem 1rem;background:var(--color-paper);border:1px solid var(--color-cream-dark);border-radius:2px;transition:all 0.2s;text-align:center;text-decoration:none;" onmouseover="this.style.borderColor='var(--color-maroon)';this.style.boxShadow='0 4px 14px rgba(0,0,0,0.08)'" onmouseout="this.style.borderColor='var(--color-cream-dark)';this.style.boxShadow=''" {{ block.shopify_attributes }}>
          <div class="concern-icon" style="width:44px;height:44px;border-radius:50%;background:rgba(15,90,67,0.08);display:flex;align-items:center;justify-content:center;color:var(--color-maroon);transition:all 0.2s;">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'droplet' -%}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3.75c.966 0 1.75.784 1.75 1.75v1c0 .966-.784 1.75-1.75 1.75S10.25 7.466 10.25 6.5v-1c0-.966.784-1.75 1.75-1.75z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 9.25C8.548 9.25 5.75 12.048 5.75 15.5c0 2.623 1.5 4.9 3.686 6.02.453.232.972.23 1.42-.003l1.144-.62 1.144.62c.448.233.967.235 1.42.003C16.75 20.4 18.25 18.123 18.25 15.5c0-3.452-2.798-6.25-6.25-6.25z"/>
                {%- when 'sparkle' -%}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/>
                {%- when 'filter' -%}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/>
                {%- when 'clock' -%}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                {%- when 'sun' -%}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
                {%- when 'heart' -%}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                {%- when 'moon' -%}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
                {%- when 'arrow-up' -%}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75L12 4.5 6.75 9.75"/>
              {%- endcase -%}
            </svg>
          </div>
          <div>
            <p style="font-size:11px;font-weight:700;color:var(--color-charcoal);line-height:1.3;">{{ block.settings.title }}</p>
            <p style="font-size:9px;color:var(--color-muted);margin-top:2px;">{{ concern_col.products_count | default: 0 }} product{{ concern_col.products_count | pluralize: "", "s" }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.concern-card-wrap { grid-template-columns: repeat(2,1fr); }
@media (min-width:640px) {
  .concern-card-wrap { grid-template-columns: repeat(4,1fr); }
}
@media (min-width:1024px) {
  .concern-card-wrap { grid-template-columns: repeat(8,1fr); }
}
.concern-card:hover .concern-icon { background: var(--color-maroon); color: #fff; }
</style>

{% schema %}
{
  "name": "Beauty Shop by Concern",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Personalised Care" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Concern" }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Dry Skin" },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "droplet", "label": "Droplet" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "filter", "label": "Filter" },
            { "value": "clock", "label": "Clock" },
            { "value": "sun", "label": "Sun" },
            { "value": "heart", "label": "Heart" },
            { "value": "moon", "label": "Moon" },
            { "value": "arrow-up", "label": "Arrow up" }
          ],
          "default": "droplet"
        },
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beauty Shop by Concern",
      "blocks": [
        { "type": "concern", "settings": { "title": "Dry Skin", "icon": "droplet" } },
        { "type": "concern", "settings": { "title": "Radiant Glow", "icon": "sparkle" } },
        { "type": "concern", "settings": { "title": "Acne & Blemishes", "icon": "filter" } },
        { "type": "concern", "settings": { "title": "Anti-Aging", "icon": "clock" } },
        { "type": "concern", "settings": { "title": "Oily Skin", "icon": "sun" } },
        { "type": "concern", "settings": { "title": "Sensitive Skin", "icon": "heart" } },
        { "type": "concern", "settings": { "title": "Night Repair", "icon": "moon" } },
        { "type": "concern", "settings": { "title": "Scalp Health", "icon": "arrow-up" } }
      ]
    }
  ]
}
{% endschema %}
