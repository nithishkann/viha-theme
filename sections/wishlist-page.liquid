{%- comment -%} Wishlist page — mostly functional (localStorage-driven JS), header + empty-state copy is editable {%- endcomment -%}
<section style="background:var(--color-paper);padding:3.5rem 1.5rem 2rem;">
  <div style="max-width:1200px;margin:0 auto;">
    <p style="font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Your Collection' }}</p>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,2.75rem);font-weight:900;color:var(--color-maroon);line-height:1.1;margin-bottom:0.25rem;">{{ section.settings.heading | default: 'Saved Items' }}</h1>
    <p id="wishlist-count-text" style="font-size:13px;color:rgba(45,45,45,0.5);margin-top:0.5rem;">Loading your saved items...</p>
  </div>
</section>

<div style="background:var(--color-paper);padding:0 1.5rem 5rem;">
  <div style="max-width:1200px;margin:0 auto;">

    {%- comment -%} Empty state {%- endcomment -%}
    <div id="wishlist-empty" style="display:none;text-align:center;padding:5rem 1.5rem;">
      <div style="width:72px;height:72px;border-radius:50%;background:var(--color-cream);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
        <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="color:rgba(45,45,45,0.3);" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
        </svg>
      </div>
      <h2 style="font-family:var(--font-heading);font-size:1.5rem;font-weight:900;color:var(--color-maroon);margin-bottom:0.75rem;">{{ section.settings.empty_heading | default: 'No saved items yet' }}</h2>
      <p style="font-size:13px;color:rgba(45,45,45,0.55);max-width:360px;margin:0 auto 2rem;line-height:1.75;">{{ section.settings.empty_text | default: 'Tap the heart icon on any product to save it here for later.' }}</p>
      <a href="{{ section.settings.empty_button_url | default: '/collections/all' }}" class="btn btn--primary" style="display:inline-flex;align-items:center;gap:8px;">
        {{ section.settings.empty_button_label | default: 'Explore Sacred Catalog' }}
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>

    {%- comment -%} Loading skeleton {%- endcomment -%}
    <div id="wishlist-loading" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin-top:0.5rem;">
      {%- for i in (1..4) -%}
        <div style="background:var(--color-cream);border-radius:2px;overflow:hidden;animation:pulse 1.5s ease-in-out infinite;">
          <div style="aspect-ratio:4/5;background:var(--color-cream-dark);"></div>
          <div style="padding:0.875rem;">
            <div style="height:10px;background:var(--color-cream-dark);border-radius:2px;margin-bottom:8px;width:60%;"></div>
            <div style="height:13px;background:var(--color-cream-dark);border-radius:2px;margin-bottom:6px;"></div>
            <div style="height:13px;background:var(--color-cream-dark);border-radius:2px;width:80%;"></div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Product grid {%- endcomment -%}
    <div id="wishlist-grid" style="display:none;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin-top:0.5rem;">
    </div>

    {%- comment -%} Clear all button {%- endcomment -%}
    <div id="wishlist-clear-wrap" style="display:none;margin-top:2.5rem;padding-top:1.5rem;border-top:1px solid var(--color-cream-dark);text-align:right;">
      <button id="wishlist-clear-btn"
        style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:rgba(45,45,45,0.45);background:none;border:none;cursor:pointer;padding:0.5rem 0;"
        onmouseover="this.style.color='var(--color-maroon)'" onmouseout="this.style.color='rgba(45,45,45,0.45)'">
        Clear All Saved Items
      </button>
    </div>

  </div>
</div>

<style>
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.wl-card { background: #fff; border: 1px solid var(--color-cream-dark); border-radius: 2px; overflow: hidden; position: relative; transition: box-shadow 0.2s; cursor: pointer; }
.wl-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
.wl-card__img-wrap { aspect-ratio: 4/5; overflow: hidden; position: relative; background: var(--color-cream); }
.wl-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; display: block; }
.wl-card:hover .wl-card__img { transform: scale(1.04); }
.wl-card__remove { position: absolute; top: 8px; right: 8px; width: 30px; height: 30px; border-radius: 50%; background: rgba(255,255,255,0.92); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--color-maroon); z-index: 2; }
.wl-card__body { padding: 0.875rem; }
.wl-card__cat { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(45,45,45,0.45); display: block; margin-bottom: 4px; }
.wl-card__name { font-size: 13px; font-weight: 600; color: var(--color-charcoal); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 0.625rem; text-decoration: none; }
.wl-card__name:hover { color: var(--color-maroon); }
.wl-card__footer { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
.wl-card__price { font-size: 14px; font-weight: 700; color: var(--color-maroon); }
.wl-card__atc { width: 32px; height: 32px; border-radius: 4px; background: var(--color-maroon); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
.wl-card__atc:hover { opacity: 0.85; }
</style>

<script>
(function() {
  var STORAGE_KEY = 'viha_wishlist';

  // Escape product fields (from localStorage / bulk-imported catalog) before
  // interpolating into innerHTML, to prevent stored-XSS via a crafted title.
  function esc(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function getWishlist() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { return []; }
  }
  function saveWishlist(list) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
  }
  function removeFromWishlist(handle) {
    var list = getWishlist().filter(function(h) { return h !== handle; });
    saveWishlist(list);
    return list;
  }

  function formatMoney(cents) {
    return '₹' + (cents / 100).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function renderCard(product) {
    var img = (product.featured_image || '').replace(/\.jpg|\.png|\.webp/i, function(ext) { return '_400x500' + ext; });
    var price = formatMoney(product.price);
    var compare = product.compare_at_price > product.price ? formatMoney(product.compare_at_price) : '';
    var available = product.available !== false;

    var card = document.createElement('div');
    card.className = 'wl-card';
    card.dataset.handle = product.handle;
    card.innerHTML = [
      '<div class="wl-card__img-wrap">',
        img ? '<img class="wl-card__img" src="' + encodeURI(img) + '" alt="' + esc(product.title) + '" loading="lazy">' : '',
        '<button class="wl-card__remove" aria-label="Remove from saved" data-remove="' + esc(product.handle) + '">',
          '<svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">',
            '<path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>',
          '</svg>',
        '</button>',
      '</div>',
      '<div class="wl-card__body">',
        '<span class="wl-card__cat">' + esc(product.type || product.vendor || '') + '</span>',
        '<a href="/products/' + encodeURIComponent(product.handle || '') + '" class="wl-card__name">' + esc(product.title) + '</a>',
        '<div class="wl-card__footer">',
          '<span class="wl-card__price">' + price + (compare ? ' <s style="font-size:11px;font-weight:400;color:rgba(45,45,45,0.4);">' + compare + '</s>' : '') + '</span>',
          available
            ? '<button class="wl-card__atc" aria-label="Add to cart" data-variant="' + (product.variants && product.variants[0] ? product.variants[0].id : '') + '"><svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/></svg></button>'
            : '<span style="font-size:10px;color:rgba(45,45,45,0.4);font-weight:700;text-transform:uppercase;letter-spacing:0.1em;">Sold out</span>',
        '</div>',
      '</div>'
    ].join('');
    return card;
  }

  function showGrid(products) {
    var grid = document.getElementById('wishlist-grid');
    var empty = document.getElementById('wishlist-empty');
    var loading = document.getElementById('wishlist-loading');
    var clearWrap = document.getElementById('wishlist-clear-wrap');
    var countText = document.getElementById('wishlist-count-text');

    loading.style.display = 'none';

    if (!products || products.length === 0) {
      grid.style.display = 'none';
      clearWrap.style.display = 'none';
      empty.style.display = 'block';
      countText.textContent = '0 saved items';
      return;
    }

    empty.style.display = 'none';
    grid.style.display = 'grid';
    clearWrap.style.display = 'block';
    countText.textContent = products.length + ' saved item' + (products.length === 1 ? '' : 's');

    grid.innerHTML = '';
    products.forEach(function(p) { grid.appendChild(renderCard(p)); });
  }

  function fetchProduct(handle) {
    return fetch('/products/' + handle + '.js')
      .then(function(r) { return r.ok ? r.json() : null; })
      .catch(function() { return null; });
  }

  function init() {
    var handles = getWishlist();
    if (handles.length === 0) {
      showGrid([]);
      return;
    }
    Promise.all(handles.map(fetchProduct)).then(function(products) {
      showGrid(products.filter(Boolean));
    });
  }

  // Remove button handler
  document.addEventListener('click', function(e) {
    var removeBtn = e.target.closest('[data-remove]');
    if (removeBtn) {
      e.preventDefault();
      e.stopPropagation();
      var handle = removeBtn.dataset.remove;
      var remaining = removeFromWishlist(handle);
      var card = document.querySelector('.wl-card[data-handle="' + handle + '"]');
      if (card) {
        card.style.transition = 'opacity 0.25s, transform 0.25s';
        card.style.opacity = '0';
        card.style.transform = 'scale(0.95)';
        setTimeout(function() { card.remove(); }, 260);
      }
      var countText = document.getElementById('wishlist-count-text');
      var clearWrap = document.getElementById('wishlist-clear-wrap');
      var n = remaining.length;
      countText.textContent = n + ' saved item' + (n === 1 ? '' : 's');
      if (n === 0) {
        setTimeout(function() {
          document.getElementById('wishlist-grid').style.display = 'none';
          clearWrap.style.display = 'none';
          document.getElementById('wishlist-empty').style.display = 'block';
          countText.textContent = '0 saved items';
        }, 300);
      }
    }

    // Add to cart handler
    var atcBtn = e.target.closest('[data-variant]');
    if (atcBtn) {
      e.preventDefault();
      e.stopPropagation();
      var variantId = atcBtn.dataset.variant;
      if (!variantId) return;
      atcBtn.disabled = true;
      atcBtn.style.opacity = '0.6';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
      }).then(function() {
        atcBtn.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';
        atcBtn.style.background = '#0f5a43';
        atcBtn.style.opacity = '1';
        setTimeout(function() {
          atcBtn.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/></svg>';
          atcBtn.style.background = 'var(--color-maroon)';
          atcBtn.disabled = false;
        }, 2000);
        document.dispatchEvent(new CustomEvent('cart:updated'));
      }).catch(function() {
        atcBtn.disabled = false;
        atcBtn.style.opacity = '1';
      });
    }
  });

  // Clear all
  document.getElementById('wishlist-clear-btn').addEventListener('click', function() {
    if (!confirm('Remove all saved items?')) return;
    saveWishlist([]);
    showGrid([]);
  });

  // Sync wishlist toggle from product cards
  document.addEventListener('wishlist:updated', function() { init(); });

  init();
})();
</script>

{% schema %}
{
  "name": "Wishlist Page",
  "settings": [
    { "type": "text",     "id": "eyebrow",             "label": "Eyebrow text",         "default": "Your Collection" },
    { "type": "text",     "id": "heading",              "label": "Heading",              "default": "Saved Items" },
    { "type": "text",     "id": "empty_heading",        "label": "Empty state heading",  "default": "No saved items yet" },
    { "type": "textarea", "id": "empty_text",           "label": "Empty state text" },
    { "type": "text",     "id": "empty_button_label",   "label": "Empty state button label", "default": "Explore Sacred Catalog" },
    { "type": "url",      "id": "empty_button_url",     "label": "Empty state button link" }
  ],
  "presets": [{ "name": "Wishlist Page" }]
}
{% endschema %}
