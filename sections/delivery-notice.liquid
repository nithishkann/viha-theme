{%- comment -%}
  Delivery notice popup — site-wide dismissible notice (shown once per browser
  session). Rendered statically from theme.liquid; fully client-editable in
  Theme Editor → any page → "Delivery notice" section.
{%- endcomment -%}

{%- if section.settings.enabled -%}
<div class="delivery-notice" data-delivery-notice hidden>
  <div class="delivery-notice__overlay" data-notice-close aria-hidden="true"></div>
  <div class="delivery-notice__card" role="dialog" aria-modal="true" aria-labelledby="delivery-notice-title">
    <button type="button" class="delivery-notice__x" data-notice-close aria-label="Close notice">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <span class="delivery-notice__eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="delivery-notice__title" id="delivery-notice-title">{{ section.settings.heading }}</h2>
    <span class="delivery-notice__rule" aria-hidden="true"></span>
    <div class="delivery-notice__body rte">{{ section.settings.body }}</div>
    <button type="button" class="btn btn--primary delivery-notice__ok" data-notice-close>
      {{ section.settings.button_label }}
    </button>
  </div>
</div>

<style>
.delivery-notice { position: fixed; inset: 0; z-index: 250; display: flex; align-items: center; justify-content: center; padding: 1.25rem; }
.delivery-notice[hidden] { display: none; }
.delivery-notice__overlay { position: absolute; inset: 0; background: rgba(20, 15, 10, 0.55); }
.delivery-notice__card { position: relative; background: var(--color-cream, #FDF9F1); max-width: 460px; width: 100%; max-height: 85vh; overflow-y: auto; padding: 2.25rem 1.75rem 1.75rem; border-radius: 3px; border-top: 3px solid var(--color-gold); text-align: center; box-shadow: 0 24px 60px rgba(0,0,0,0.3); }
.delivery-notice__x { position: absolute; top: 10px; right: 10px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: none; border: 0; cursor: pointer; color: var(--color-charcoal); }
.delivery-notice__x:hover { color: var(--color-maroon); }
.delivery-notice__eyebrow { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.22em; color: var(--color-gold); margin-bottom: 6px; }
.delivery-notice__title { font-family: var(--font-heading); font-size: 20px; color: var(--color-maroon); margin: 0 0 0.75rem; }
.delivery-notice__rule { display: inline-block; width: 48px; height: 2px; background: var(--color-gold); margin-bottom: 1rem; }
.delivery-notice__body { font-size: 13px; line-height: 1.8; color: var(--color-charcoal); text-align: left; margin-bottom: 1.5rem; }
.delivery-notice__body p { margin: 0 0 0.75rem; }
.delivery-notice__body strong { color: var(--color-maroon); }
.delivery-notice__ok { width: 100%; min-height: 46px; }
@media (max-width: 480px) { .delivery-notice__card { padding: 2rem 1.25rem 1.25rem; } }
</style>

<script>
  (function () {
    var KEY = 'viha_notice_closed';
    var el = document.querySelector('[data-delivery-notice]');
    if (!el) return;
    try { if (sessionStorage.getItem(KEY)) return; } catch (e) {}
    // In the Theme Editor, always show so the client can style it.
    var inEditor = window.Shopify && window.Shopify.designMode;

    function close() {
      el.hidden = true;
      document.body.style.overflow = '';
      try { if (!inEditor) sessionStorage.setItem(KEY, '1'); } catch (e) {}
    }
    function open() {
      el.hidden = false;
      document.body.style.overflow = 'hidden';
      var x = el.querySelector('.delivery-notice__x');
      if (x) x.focus();
    }
    el.querySelectorAll('[data-notice-close]').forEach(function (btn) {
      btn.addEventListener('click', close);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !el.hidden) close();
    });
    setTimeout(open, 900);
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Delivery notice",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Show notice popup", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "A note from Viha" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Delivery Time: 8–10 Working Days" },
    {
      "type": "richtext",
      "id": "body",
      "label": "Notice text",
      "default": "<p>You can track your parcels on the India Post website with your tracking number.</p><p>Kindly allow us to deliver our products to you in their best form — we require at least 7–8 working days for delivery.</p><p><strong>NOTE:</strong> Day of booking, Sundays, public holidays and Tamil Nadu festival days are NOT considered working days. Minimum 14 working days required for delivery.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Got it, continue shopping" }
  ]
}
{% endschema %}
