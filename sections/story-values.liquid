{%- comment -%} Our Story page — core values, each a block {%- endcomment -%}
<section style="background:var(--color-cream);padding:5rem 1.5rem;">
  <div style="max-width:1100px;margin:0 auto;text-align:center;">
    <p style="font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'What We Stand For' }}</p>
    <h2 style="font-family:var(--font-heading);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:var(--color-maroon);margin-bottom:3rem;">{{ section.settings.heading | default: 'Our Core Values' }}</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2rem;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div style="background:var(--color-paper);padding:2rem;border-radius:2px;border:1px solid var(--color-cream-dark);text-align:left;" {{ block.shopify_attributes }}>
            <div style="width:40px;height:40px;background:var(--color-maroon);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#fff" stroke-width="1.5" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'check' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  {%- when 'sparkle' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                  {%- when 'sun' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
                  {%- when 'heart' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                {%- endcase -%}
              </svg>
            </div>
            <h3 style="font-family:var(--font-heading);font-size:1rem;font-weight:900;color:var(--color-maroon);margin-bottom:0.625rem;">{{ block.settings.title }}</h3>
            <p style="font-size:13px;color:rgba(45,45,45,0.7);line-height:1.75;">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story Values",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "What We Stand For" },
    { "type": "text", "id": "heading", "label": "Heading",      "default": "Our Core Values" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "check", "label": "Check" },
          { "value": "sparkle", "label": "Sparkle" },
          { "value": "sun", "label": "Sun" },
          { "value": "heart", "label": "Heart" }
        ], "default": "check" },
        { "type": "text",     "id": "title",       "label": "Title", "default": "Authentic Sourcing" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Values",
      "blocks": [
        { "type": "value", "settings": { "icon": "check", "title": "Authentic Sourcing", "description": "Direct from master craftsmen and traditional healers across India — never mass-produced, never compromised." } },
        { "type": "value", "settings": { "icon": "sparkle", "title": "Sacred Craftsmanship", "description": "Every item is hand-selected for energy, intention, and quality by Mrs Anitha Kuppusamy personally." } },
        { "type": "value", "settings": { "icon": "sun", "title": "Heritage Preservation", "description": "We document and preserve endangered craft traditions by ensuring artisans receive fair trade prices." } },
        { "type": "value", "settings": { "icon": "heart", "title": "Holistic Wellness", "description": "Rooted in Ayurveda and Siddha medicine — products that nourish body, mind, and spirit together." } }
      ]
    }
  ]
}
{% endschema %}
