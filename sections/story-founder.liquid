{%- comment -%} Our Story page — founder portrait + narrative {%- endcomment -%}
<section style="background:var(--color-paper);padding:5rem 1.5rem;">
  <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr;gap:3rem;align-items:center;">
    <div class="story-two-col" style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">

      {%- comment -%} Founder portrait {%- endcomment -%}
      <div style="aspect-ratio:3/4;background:var(--color-cream-dark);border-radius:2px;overflow:hidden;position:relative;">
        {%- if section.settings.founder_image != blank -%}
          <img src="{{ section.settings.founder_image | img_url: '600x' }}" alt="{{ section.settings.founder_name | default: 'Founder' }}" style="width:100%;height:100%;object-fit:cover;">
        {%- elsif settings.logo != blank -%}
          <img src="{{ settings.logo | img_url: '600x' }}" alt="{{ section.settings.founder_name | default: 'Founder' }}" style="width:100%;height:100%;object-fit:cover;">
        {%- else -%}
          <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;padding:2rem;text-align:center;">
            <svg width="64" height="64" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="color:rgba(45,45,45,0.2);" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
            </svg>
            <p style="font-size:11px;color:rgba(45,45,45,0.35);font-style:italic;">Add a founder photo in this section's settings</p>
          </div>
        {%- endif -%}
        <div style="position:absolute;bottom:0;left:0;right:0;padding:1.5rem;background:linear-gradient(to top,rgba(0,0,0,0.6),transparent);">
          <p style="font-family:var(--font-heading);font-size:1.1rem;font-weight:900;color:#fff;margin:0;">{{ section.settings.founder_name | default: 'Mrs. Anitha Kuppusamy' }}</p>
          <p style="font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);margin-top:4px;">{{ section.settings.founder_title | default: 'Founder · Viha Heritage Store' }}</p>
        </div>
      </div>

      {%- comment -%} Founder story text {%- endcomment -%}
      <div>
        <p style="font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-gold);margin-bottom:1rem;">{{ section.settings.eyebrow | default: 'The Founder' }}</p>
        <h2 style="font-family:var(--font-heading);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:var(--color-maroon);line-height:1.15;margin-bottom:1.5rem;">{{ section.settings.heading | default: 'A Devotion Turned into a Mission' }}</h2>
        <div style="font-size:14px;color:rgba(45,45,45,0.75);line-height:1.85;">
          {{ section.settings.body | default: "<p>Viha Heritage Store was born from a deep reverence for Indian spiritual traditions and holistic wellness. Mrs Anitha Kuppusamy grew up immersed in the rituals, fragrances, and sacred craftsmanship of Tamil Nadu — and she recognised that these treasures deserved to reach devotees worldwide.</p><p>Every product we offer — from sacred brass idols to handcrafted Ayurvedic soaps — is personally selected and curated to bring authentic, time-honoured essentials into your home. We source directly from master craftsmen and traditional healers who have practised their trade for generations.</p><p>Rooted in Tamil Nadu's rich cultural heritage, Viha is more than a store. It is a living bridge between the wisdom of our ancestors and the needs of contemporary devotees worldwide.</p>" }}
        </div>
        {%- if section.settings.quote != blank -%}
          <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--color-cream-dark);">
            <p style="font-family:var(--font-heading);font-size:1.1rem;font-weight:900;color:var(--color-maroon);font-style:italic;">&ldquo;{{ section.settings.quote }}&rdquo;</p>
            <p style="font-size:11px;color:rgba(45,45,45,0.5);margin-top:6px;text-transform:uppercase;letter-spacing:0.12em;">— {{ section.settings.quote_attribution | default: 'Anitha Kuppusamy' }}</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
@media (max-width: 767px) {
  .story-two-col { grid-template-columns: 1fr !important; }
}
</style>

{% schema %}
{
  "name": "Story Founder",
  "settings": [
    { "type": "image_picker", "id": "founder_image",       "label": "Founder photo" },
    { "type": "text",         "id": "founder_name",        "label": "Founder name",  "default": "Mrs. Anitha Kuppusamy" },
    { "type": "text",         "id": "founder_title",       "label": "Founder title", "default": "Founder · Viha Heritage Store" },
    { "type": "text",         "id": "eyebrow",              "label": "Eyebrow text",  "default": "The Founder" },
    { "type": "text",         "id": "heading",              "label": "Heading",       "default": "A Devotion Turned into a Mission" },
    { "type": "richtext",     "id": "body",                 "label": "Story body" },
    { "type": "text",         "id": "quote",                "label": "Pull quote" },
    { "type": "text",         "id": "quote_attribution",    "label": "Quote attribution", "default": "Anitha Kuppusamy" }
  ],
  "presets": [
    {
      "name": "Story Founder",
      "settings": { "quote": "Authenticity is not a feature. It is the foundation." }
    }
  ]
}
{% endschema %}
