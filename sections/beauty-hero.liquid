{%- comment -%} Beauty page hero — editable image, heading, subtext, CTAs {%- endcomment -%}
<section style="position:relative;width:100%;min-height:520px;height:60vh;max-height:700px;background:var(--color-maroon-dark);display:flex;align-items:flex-end;overflow:hidden;">
  {%- if section.settings.bg_image != blank -%}
    <div style="position:absolute;inset:0;background-image:url('{{ section.settings.bg_image | img_url: '1920x' }}');background-size:cover;background-position:center;filter:brightness(0.35);"></div>
  {%- else -%}
    <div style="position:absolute;inset:0;background:var(--color-maroon-dark);"></div>
  {%- endif -%}
  <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.80) 0%,rgba(0,0,0,0.15) 60%,transparent 100%);"></div>

  <nav aria-label="Breadcrumb" style="position:absolute;top:1.5rem;left:3rem;z-index:2;display:flex;align-items:center;gap:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:rgba(255,255,255,0.45);">
    <a href="/" style="color:inherit;transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">Home</a>
    <span>/</span>
    <span style="color:var(--color-gold);">{{ section.settings.breadcrumb_label | default: 'Beauty & Wellness' }}</span>
  </nav>

  <div style="position:relative;z-index:1;max-width:var(--max-w);margin:0 auto;width:100%;padding:0 3rem 4.5rem;">
    <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.22em;color:var(--color-gold);margin-bottom:1rem;">{{ section.settings.eyebrow | default: 'Viha Beauty & Wellness' }}</span>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,6vw,4.5rem);font-weight:900;color:#fff;line-height:1.05;margin-bottom:1.25rem;max-width:640px;">
      {{ section.settings.heading | default: 'Ancestral Beauty, Timeless Ritual.' }}
    </h1>
    <p style="font-size:14px;color:rgba(255,255,255,0.65);max-width:440px;margin-bottom:2rem;line-height:1.75;">
      {{ section.settings.subtext | default: 'Plant-based formulations rooted in five thousand years of Ayurvedic wisdom.' }}
    </p>
    <div style="display:flex;flex-wrap:wrap;gap:12px;">
      <a href="{{ section.settings.cta_primary_url | default: '/collections/ayurveda-herbal' }}" class="btn btn--primary" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;font-size:11px;">
        {{ section.settings.cta_primary_label | default: 'Explore Collection' }}
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
      <a href="#beauty-journal" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.16em;color:#fff;border:1px solid rgba(255,255,255,0.35);transition:background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.10)'" onmouseout="this.style.background='transparent'">
        {{ section.settings.cta_secondary_label | default: 'Beauty Journal' }}
      </a>
    </div>
  </div>

  {%- comment -%} Trust strip {%- endcomment -%}
  <div style="position:absolute;bottom:0;left:0;right:0;z-index:1;border-top:1px solid rgba(255,255,255,0.10);background:rgba(0,0,0,0.40);padding:12px 0;overflow:hidden;">
    <div style="max-width:var(--max-w);margin:0 auto;padding:0 3rem;display:flex;align-items:center;justify-content:center;gap:2.5rem;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:rgba(255,255,255,0.50);flex-wrap:wrap;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust_item' -%}
          {%- if forloop.index > 1 -%}<span style="color:rgba(184,137,61,0.4);">|</span>{%- endif -%}
          <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beauty Hero",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "text", "id": "breadcrumb_label", "label": "Breadcrumb label", "default": "Beauty & Wellness" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Viha Beauty & Wellness" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ancestral Beauty, Timeless Ritual." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Plant-based formulations rooted in five thousand years of Ayurvedic wisdom." },
    { "type": "text", "id": "cta_primary_label", "label": "Primary button label", "default": "Explore Collection" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary button link" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary button label (links to Beauty Journal on this page)", "default": "Beauty Journal" }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust strip item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "100% Natural Ingredients" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beauty Hero",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "100% Natural Ingredients" } },
        { "type": "trust_item", "settings": { "text": "No Parabens or SLS" } },
        { "type": "trust_item", "settings": { "text": "Cruelty Free" } },
        { "type": "trust_item", "settings": { "text": "Ayurvedic Formulations" } }
      ]
    }
  ]
}
{% endschema %}
