{%- comment -%} Contact page — header, form, and editable info sidebar {%- endcomment -%}
<section style="background:var(--color-paper);padding:3.5rem 1.5rem 2rem;">
  <div style="max-width:1100px;margin:0 auto;">
    <p style="font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Reach Out' }}</p>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3rem);font-weight:900;color:var(--color-maroon);line-height:1.1;margin-bottom:0.75rem;">{{ section.settings.heading | default: 'Contact Us' }}</h1>
    <p style="font-size:14px;color:rgba(45,45,45,0.65);max-width:480px;line-height:1.75;">{{ section.settings.intro_text | default: "Have a question about our products, your order, or want to know more about our heritage? We'd love to hear from you." }}</p>
  </div>
</section>

<div style="background:var(--color-paper);padding:0 1.5rem 5rem;">
  <div class="contact-grid" style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1.2fr 0.8fr;gap:4rem;align-items:start;">

    {%- comment -%} ── Contact form ─────────────────────────────────────────── {%- endcomment -%}
    <div style="background:#fff;padding:2.5rem;border:1px solid var(--color-cream-dark);border-radius:2px;">
      <h2 style="font-family:var(--font-heading);font-size:1.25rem;font-weight:900;color:var(--color-maroon);margin-bottom:1.75rem;">{{ section.settings.form_heading | default: 'Send us a Message' }}</h2>

      {%- form 'contact', id: 'viha-contact-form' -%}
        {% if form.posted_successfully? %}
          <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:2px;padding:1rem 1.25rem;margin-bottom:1.5rem;color:#166534;font-size:13px;font-weight:600;">
            ✓ Your message was sent successfully. We'll get back to you within 24 hours.
          </div>
        {% endif %}
        {% if form.errors %}
          <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:2px;padding:1rem 1.25rem;margin-bottom:1.5rem;color:#991b1b;font-size:13px;">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
          <div>
            <label for="contact-name" style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.6);margin-bottom:6px;">Full Name *</label>
            <input type="text" id="contact-name" name="contact[name]" required placeholder="Your name"
              style="width:100%;padding:0.75rem 1rem;border:1.5px solid var(--color-cream-dark);border-radius:2px;font-size:14px;font-family:inherit;color:var(--color-charcoal);background:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--color-maroon)'" onblur="this.style.borderColor='var(--color-cream-dark)'">
          </div>
          <div>
            <label for="contact-email" style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.6);margin-bottom:6px;">Email Address *</label>
            <input type="email" id="contact-email" name="contact[email]" required placeholder="your@email.com"
              style="width:100%;padding:0.75rem 1rem;border:1.5px solid var(--color-cream-dark);border-radius:2px;font-size:14px;font-family:inherit;color:var(--color-charcoal);background:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--color-maroon)'" onblur="this.style.borderColor='var(--color-cream-dark)'">
          </div>
        </div>

        <div style="margin-bottom:1rem;">
          <label for="contact-phone" style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.6);margin-bottom:6px;">Phone Number</label>
          <input type="tel" id="contact-phone" name="contact[phone]" placeholder="Your 10-digit mobile number" autocomplete="tel"
            style="width:100%;padding:0.75rem 1rem;border:1.5px solid var(--color-cream-dark);border-radius:2px;font-size:14px;font-family:inherit;color:var(--color-charcoal);background:#fff;outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--color-maroon)'" onblur="this.style.borderColor='var(--color-cream-dark)'">
        </div>

        <div style="margin-bottom:1rem;">
          <label for="contact-subject" style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.6);margin-bottom:6px;">Subject</label>
          <select id="contact-subject" name="contact[subject]"
            style="width:100%;padding:0.75rem 1rem;border:1.5px solid var(--color-cream-dark);border-radius:2px;font-size:14px;font-family:inherit;color:var(--color-charcoal);background:#fff;outline:none;cursor:pointer;">
            <option value="">Select a topic</option>
            <option value="Order enquiry">Order Enquiry</option>
            <option value="Product question">Product Question</option>
            <option value="Shipping & delivery">Shipping &amp; Delivery</option>
            <option value="Returns & refunds">Returns &amp; Refunds</option>
            <option value="Wholesale / bulk">Wholesale / Bulk Order</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div style="margin-bottom:1.5rem;">
          <label for="contact-body" style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.6);margin-bottom:6px;">Message *</label>
          <textarea id="contact-body" name="contact[body]" rows="5" required placeholder="Tell us how we can help you..."
            style="width:100%;padding:0.75rem 1rem;border:1.5px solid var(--color-cream-dark);border-radius:2px;font-size:14px;font-family:inherit;color:var(--color-charcoal);background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;line-height:1.6;"
            onfocus="this.style.borderColor='var(--color-maroon)'" onblur="this.style.borderColor='var(--color-cream-dark)'"></textarea>
        </div>

        <button type="submit" class="btn btn--primary" style="width:100%;justify-content:center;">
          Send Message
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin-left:6px;"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
        </button>
      {%- endform -%}
    </div>

    {%- comment -%} ── Contact info sidebar ──────────────────────────────────── {%- endcomment -%}
    <div style="display:flex;flex-direction:column;gap:1.5rem;">

      <div style="background:var(--color-maroon);padding:2rem;border-radius:2px;color:#fff;">
        <h3 style="font-family:var(--font-heading);font-size:1rem;font-weight:900;margin-bottom:1.25rem;letter-spacing:0.04em;">{{ section.settings.store_heading | default: 'Visit Our Store' }}</h3>
        <address style="font-style:normal;font-size:13px;color:rgba(255,255,255,0.8);line-height:2;">
          {{ section.settings.store_address | default: "Viha<br>No 10, Bhagirathy Street, Raja Annamalaipuram<br>Chennai, Tamil Nadu 600 028<br>(Near Kamakshi Amman Temple)" }}
        </address>
        {%- assign contact_map_url = section.settings.map_url | default: 'https://maps.app.goo.gl/4EASzgQfbGdXkLR57' -%}
        {%- if contact_map_url != blank -%}
        <a href="{{ contact_map_url }}" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:7px;margin-top:1.25rem;padding:10px 18px;background:#fff;color:var(--color-maroon);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;border-radius:2px;text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          {{ section.settings.map_button_label | default: 'Get Directions' }}
        </a>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'contact_item' -%}
          <div style="background:#fff;padding:1.25rem 1.5rem;border:1px solid var(--color-cream-dark);border-radius:2px;display:flex;align-items:flex-start;gap:1rem;" {{ block.shopify_attributes }}>
            <div style="width:36px;height:36px;border-radius:50%;background:var(--color-cream);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color:var(--color-maroon);" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'email' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.844a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/>
                  {%- when 'whatsapp' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.338c0 5.487 4.575 9.975 10.222 9.975 1.584 0 3.085-.37 4.42-1.03l3.358.838-.838-3.358A9.826 9.826 0 0021.75 8.25c0-5.487-4.576-9.975-10.222-9.975-5.647 0-9.278 4.488-9.278 9.975v.088z"/>
                  {%- when 'clock' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  {%- when 'phone' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                  {%- when 'location' -%}
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                {%- endcase -%}
              </svg>
            </div>
            <div>
              <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.16em;color:rgba(45,45,45,0.5);margin-bottom:3px;">{{ block.settings.label }}</p>
              <p style="font-size:13px;font-weight:600;color:var(--color-maroon);">{{ block.settings.value }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div style="background:var(--color-cream);padding:1.25rem 1.5rem;border:1px solid var(--color-cream-dark);border-radius:2px;">
        <p style="font-size:12px;color:rgba(45,45,45,0.6);line-height:1.7;">
          <strong style="color:var(--color-maroon);">{{ section.settings.note_heading | default: 'International customers:' }}</strong> {{ section.settings.note_text | default: 'We respond within 24 hours on working days. For urgent order queries, please include your order number in the subject line.' }}
        </p>
      </div>
    </div>

  </div>
</div>

<style>
@media (max-width: 767px) {
  .contact-grid { grid-template-columns: 1fr !important; }
}
</style>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    { "type": "text",     "id": "eyebrow",       "label": "Eyebrow text",  "default": "Reach Out" },
    { "type": "text",     "id": "heading",       "label": "Heading",       "default": "Contact Us" },
    { "type": "textarea", "id": "intro_text",    "label": "Intro text" },
    { "type": "text",     "id": "form_heading",  "label": "Form heading",  "default": "Send us a Message" },
    { "type": "text",     "id": "store_heading", "label": "Store card heading", "default": "Visit Our Store" },
    { "type": "richtext", "id": "store_address", "label": "Store address" },
    { "type": "url",      "id": "map_url",          "label": "Map / directions link", "info": "Google Maps link the button opens (leave blank to use the default store location)" },
    { "type": "text",     "id": "map_button_label", "label": "Map button label", "default": "Get Directions" },
    { "type": "text",     "id": "note_heading",  "label": "Note heading",  "default": "International customers:" },
    { "type": "textarea", "id": "note_text",     "label": "Note text" }
  ],
  "blocks": [
    {
      "type": "contact_item",
      "name": "Contact info item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "email", "label": "Email" },
          { "value": "whatsapp", "label": "WhatsApp" },
          { "value": "clock", "label": "Clock" },
          { "value": "phone", "label": "Phone" },
          { "value": "location", "label": "Location" }
        ], "default": "email" },
        { "type": "text", "id": "label", "label": "Label", "default": "Email" },
        { "type": "text", "id": "value", "label": "Value", "default": "info@viha.online" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Page",
      "blocks": [
        { "type": "contact_item", "settings": { "icon": "email", "label": "Email", "value": "info@viha.online" } },
        { "type": "contact_item", "settings": { "icon": "phone", "label": "Customer Care", "value": "+91 89398 99409" } },
        { "type": "contact_item", "settings": { "icon": "clock", "label": "Hours", "value": "Mon – Sat: 10:00 AM – 6:00 PM IST" } }
      ]
    }
  ]
}
{% endschema %}
