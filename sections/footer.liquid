<footer class="site-footer" role="contentinfo">
  <div class="footer__grid">

    {%- comment -%} Brand column {%- endcomment -%}
    <div>
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | img_url: 'small' }}" alt="{{ shop.name }}" height="50" style="height:50px;margin-bottom:1rem;">
      {% else %}
        <p style="font-family:var(--font-heading);font-size:1.25rem;font-weight:900;color:var(--color-maroon);margin-bottom:1rem;">{{ shop.name }}</p>
      {% endif %}
      <p style="font-size:12px;color:rgba(45,45,45,0.7);line-height:1.8;max-width:240px;">
        {{ section.settings.brand_description | default: "Bringing the wisdom of ancient Ayurvedic traditions to modern rituals — pure, authentic, and crafted with love." }}
      </p>
      <div style="display:flex;gap:0.75rem;margin-top:1.25rem;">
        {% if settings.social_instagram_link != blank %}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer"
            aria-label="{{ shop.name }} on Instagram"
            style="width:36px;height:36px;border:1px solid var(--color-cream-dark);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--color-maroon);transition:all 0.2s;"
            onmouseover="this.style.background='var(--color-maroon)';this.style.color='#fff';this.style.borderColor='var(--color-maroon)'"
            onmouseout="this.style.background='';this.style.color='var(--color-maroon)';this.style.borderColor='var(--color-cream-dark)'">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z"/>
            </svg>
          </a>
        {% endif %}
        {% if settings.social_facebook_link != blank %}
          <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer"
            aria-label="{{ shop.name }} on Facebook"
            style="width:36px;height:36px;border:1px solid var(--color-cream-dark);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--color-maroon);transition:all 0.2s;"
            onmouseover="this.style.background='var(--color-maroon)';this.style.color='#fff';this.style.borderColor='var(--color-maroon)'"
            onmouseout="this.style.background='';this.style.color='var(--color-maroon)';this.style.borderColor='var(--color-cream-dark)'">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        {% endif %}
        {% if settings.social_youtube_link != blank %}
          <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener noreferrer"
            aria-label="{{ shop.name }} on YouTube"
            style="width:36px;height:36px;border:1px solid var(--color-cream-dark);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--color-maroon);transition:all 0.2s;"
            onmouseover="this.style.background='var(--color-maroon)';this.style.color='#fff';this.style.borderColor='var(--color-maroon)'"
            onmouseout="this.style.background='';this.style.color='var(--color-maroon)';this.style.borderColor='var(--color-cream-dark)'">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>

    {%- comment -%} Quick Links {%- endcomment -%}
    <div>
      <p class="footer__heading">Quick Links</p>
      <div class="footer__links">
        <a href="/collections/all"              class="footer__link">Shop All Essentials</a>
        <a href="/collections/spiritual-pooja"  class="footer__link">Spiritual &amp; Pooja</a>
        <a href="/collections/ayurveda-herbal"  class="footer__link">Ayurveda &amp; Herbal</a>
        <a href="/pages/beauty"                 class="footer__link">Beauty &amp; Wellness</a>
        <a href="/collections/jewellery-fashion"class="footer__link">Jewellery &amp; Fashion</a>
        <a href="/collections/home-living"      class="footer__link">Home &amp; Living</a>
        <a href="/collections/food-organic"     class="footer__link">Food &amp; Organic</a>
        <a href="/collections/new-arrivals"     class="footer__link">New Arrivals ✦</a>
        <a href="/pages/our-story"              class="footer__link">Our Heritage</a>
      </div>
    </div>

    {%- comment -%} Help & Support {%- endcomment -%}
    <div>
      <p class="footer__heading">Help &amp; Support</p>
      <div class="footer__links">
        <a href="/pages/track-order"      class="footer__link">Track My Order</a>
        <a href="/policies/shipping-policy" class="footer__link">Shipping Policy</a>
        <a href="/policies/refund-policy"   class="footer__link">Returns &amp; Refunds</a>
        <a href="/pages/faq"              class="footer__link">FAQ</a>
        <a href="/pages/contact"          class="footer__link">Contact Us</a>
        <a href="{{ routes.account_url }}" class="footer__link">My Account</a>
      </div>
    </div>

    {%- comment -%} Contact & Trust {%- endcomment -%}
    <div>
      <p class="footer__heading">Contact</p>
      <div class="footer__links" style="gap:8px;">
        {% if section.settings.contact_email != blank %}
          <a href="mailto:{{ section.settings.contact_email }}" class="footer__link">{{ section.settings.contact_email }}</a>
        {% endif %}
        {% if section.settings.contact_phone != blank %}
          <a href="tel:{{ section.settings.contact_phone }}" class="footer__link">{{ section.settings.contact_phone }}</a>
        {% endif %}
        <p style="color:rgba(45,45,45,0.7);margin-top:0.5rem;line-height:1.6;">
          {{ section.settings.contact_address | default: "India" }}
        </p>
      </div>
      {% if section.settings.trust_badge_heading != blank or section.settings.trust_badge_text != blank %}
      <div style="margin-top:1.25rem;padding:0.75rem 1rem;background:rgba(184,137,61,0.08);border:1px solid rgba(184,137,61,0.2);border-left:2px solid var(--color-gold);border-radius:2px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:var(--color-gold);margin-bottom:4px;">{{ section.settings.trust_badge_heading | default: "100% Pure & Natural" }}</p>
        <p style="font-size:10.5px;color:rgba(45,45,45,0.7);line-height:1.5;">{{ section.settings.trust_badge_text | default: "No parabens · No sulphates · No artificial fragrances · Cruelty-free" }}</p>
      </div>
      {% endif %}
    </div>

  </div>

  <div class="footer__bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <div class="footer__legal">
      <a href="/policies/privacy-policy">Privacy Policy</a>
      <a href="/policies/terms-of-service">Terms of Service</a>
      <a href="/policies/refund-policy">Refunds</a>
    </div>
    {%- render 'localization-form', id_suffix: 'footer', compact: true -%}
    <p>Made with love in India 🌿</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "brand_description", "label": "Brand description", "default": "Bringing the wisdom of ancient Ayurvedic traditions to modern rituals — pure, authentic, and crafted with love." },
    { "type": "text",     "id": "contact_email",     "label": "Contact email" },
    { "type": "text",     "id": "contact_phone",     "label": "Contact phone" },
    { "type": "textarea", "id": "contact_address",   "label": "Address" },
    { "type": "text",     "id": "trust_badge_heading","label": "Trust badge heading", "default": "100% Pure & Natural" },
    { "type": "text",     "id": "trust_badge_text",  "label": "Trust badge text",    "default": "No parabens · No sulphates · No artificial fragrances · Cruelty-free" }
  ]
}
{% endschema %}
