{%- assign current_product = product -%}

{%- comment -%}
  Every product also belongs to a GST tax-rate collection (Admin → Settings → Taxes →
  India → Product overrides), used for Shopify's collection-based tax overrides — not a
  real merchandising category. These get renamed/added to over time (confirmed 2026-07-02:
  "0% GST", "five gst", "twelve gst", "eighteen gst", "3% GST", "point gst"), so detect them
  by "gst" appearing in the handle/title rather than a fixed handle list, which breaks the
  moment one gets renamed. Skip them when picking "the" category collection for display
  (breadcrumb, related products).
{%- endcomment -%}
{%- assign primary_collection = blank -%}
{%- for c in current_product.collections -%}
  {%- assign c_title_lower = c.title | downcase -%}
  {%- assign is_gst_collection = false -%}
  {%- if c.handle contains 'gst' or c_title_lower contains 'gst' -%}
    {%- assign is_gst_collection = true -%}
  {%- endif -%}
  {%- if primary_collection == blank and is_gst_collection == false -%}
    {%- assign primary_collection = c -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} ── YouTube video ID extraction ──────────────────────────── {%- endcomment -%}
{%- assign yt_raw = current_product.metafields.custom.youtube_video_url | default: '' -%}
{%- assign yt_id = '' -%}
{%- if yt_raw != blank -%}
  {%- if yt_raw contains 'youtu.be/' -%}
    {%- assign yt_id = yt_raw | split: 'youtu.be/' | last | split: '?' | first -%}
  {%- elsif yt_raw contains 'youtube.com/watch' -%}
    {%- assign yt_id = yt_raw | split: 'v=' | last | split: '&' | first -%}
  {%- elsif yt_raw contains 'youtube.com/embed/' -%}
    {%- assign yt_id = yt_raw | split: 'youtube.com/embed/' | last | split: '?' | first -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} Open Graph product tags — augment the og:type=product already set in
  <head>, so shared product links (WhatsApp/Carthike, Facebook) show price + stock.
  These render nothing visually. {%- endcomment -%}
{%- assign og_variant = current_product.selected_or_first_available_variant -%}
<meta property="product:price:amount" content="{{ og_variant.price | divided_by: 100.0 }}">
<meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
<meta property="og:availability" content="{% if og_variant.available %}instock{% else %}oos{% endif %}">

<nav aria-label="Breadcrumb" class="product-breadcrumb" style="border-bottom:1px solid var(--color-cream-dark);background:var(--color-paper);">
  <ol style="display:flex;align-items:center;gap:8px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:rgba(45,45,45,0.5);list-style:none;overflow:hidden;">
    <li style="flex-shrink:0;"><a href="/" style="color:inherit;transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='inherit'">Home</a></li>
    <li aria-hidden="true" style="opacity:0.4;flex-shrink:0;">/</li>
    <li style="flex-shrink:0;"><a href="{{ primary_collection.url | default: '/collections/all' }}" style="color:inherit;transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='inherit'">{{ primary_collection.title | default: 'Shop' }}</a></li>
    <li aria-hidden="true" style="opacity:0.4;flex-shrink:0;">/</li>
    <li aria-current="page" style="color:var(--color-maroon);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ current_product.title | truncate: 30 }}</li>
  </ol>
</nav>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | json }} },
    { "@type": "ListItem", "position": 2, "name": {{ primary_collection.title | default: 'Shop' | json }}, "item": {{ primary_collection.url | default: '/collections/all' | prepend: shop.url | json }} },
    { "@type": "ListItem", "position": 3, "name": {{ current_product.title | json }}, "item": {{ shop.url | append: current_product.url | json }} }
  ]
}
</script>

{%- comment -%} Mobile-only: show title + price ABOVE the image so they're immediately visible {%- endcomment -%}
<div class="product-mob-bar">
  <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:4px;">{{ current_product.type | default: current_product.vendor }}</p>
  <h1 class="product-mob-bar__name">{{ current_product.title }}</h1>
  <div class="product-mob-bar__price">
    <span data-pdp-price>{{ current_product.selected_or_first_available_variant.price | money }}</span>
    <span data-pdp-compare>
    {%- if current_product.compare_at_price > current_product.price -%}
      <s style="font-size:0.9rem;opacity:0.45;margin-left:8px;">{{ current_product.compare_at_price | money }}</s>
      <span style="font-size:11px;background:var(--color-gold);color:#fff;padding:2px 7px;border-radius:2px;margin-left:6px;font-weight:700;">Save {{ current_product.compare_at_price | minus: current_product.price | money }}</span>
    {%- endif -%}
    </span>
  </div>
  <p style="font-size:10px;color:rgba(45,45,45,0.55);margin-top:2px;">GST and shipping calculated at checkout — not included in the price above.</p>
</div>

<div class="product-layout">

  {%- comment -%} ── Gallery ───────────────────────────────────────────── {%- endcomment -%}
  <div class="product-gallery">
    <div class="product-gallery__main">
      <img
        id="gallery-main-img"
        data-gallery-main
        src="{{ current_product.featured_image | img_url: '800x800', crop: 'center' }}"
        alt="{{ current_product.featured_image.alt | default: current_product.title | escape }}"
        width="800" height="800"
        loading="eager"
        itemprop="image"
        style="width:100%;height:100%;object-fit:contain;mix-blend-mode:multiply;padding:1.5rem;"
      >
    </div>

    <div style="display:flex;gap:8px;margin-top:12px;overflow-x:auto;" class="scrollbar-hide">
      {% for image in current_product.images limit: 5 %}
        <button data-gallery-thumb data-src="{{ image | img_url: '800x800', crop: 'center' }}"
          style="flex-shrink:0;width:64px;height:64px;border:1px solid var(--color-cream-dark);border-radius:2px;overflow:hidden;padding:4px;background:var(--color-cream);cursor:pointer;opacity:{% if forloop.first %}1{% else %}0.6{% endif %};transition:opacity 0.2s,border-color 0.2s;"
          aria-label="View image {{ forloop.index }}"
          onmouseover="this.style.borderColor='var(--color-gold)'" onmouseout="this.style.borderColor='var(--color-cream-dark)'">
          <img src="{{ image | img_url: '100x100', crop: 'center' }}" alt="{{ image.alt | default: current_product.title | escape }}" width="56" height="56" loading="lazy" style="width:100%;height:100%;object-fit:contain;mix-blend-mode:multiply;">
        </button>
      {% endfor %}

    </div>

    {%- if yt_id != blank -%}
    <div style="margin-top:12px;border:1px solid var(--color-cream-dark);border-radius:2px;overflow:hidden;">
      <div id="yt-gallery-player" style="position:relative;padding-bottom:56.25%;height:0;cursor:pointer;background:#000;"
        onclick="(function(el){var iframe=document.createElement('iframe');iframe.src='https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&rel=0';iframe.allow='accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture';iframe.allowFullscreen=true;iframe.style.cssText='position:absolute;top:0;left:0;width:100%;height:100%;border:0;';el.innerHTML='';el.style.cursor='default';el.appendChild(iframe);})(this)">
        <img
          src="https://img.youtube.com/vi/{{ yt_id }}/mqdefault.jpg"
          alt="{{ current_product.title | escape }} — Video"
          onerror="this.src='https://img.youtube.com/vi/{{ yt_id }}/hqdefault.jpg'"
          style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;">
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.18);">
          <div style="width:52px;height:52px;border-radius:50%;background:rgba(0,0,0,0.65);display:flex;align-items:center;justify-content:center;transition:transform 0.2s,background 0.2s;"
            onmouseover="this.style.background='var(--color-maroon)';this.style.transform='scale(1.1)'"
            onmouseout="this.style.background='rgba(0,0,0,0.65)';this.style.transform='scale(1)'">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white" aria-hidden="true" style="margin-left:3px;"><path d="M8 5v14l11-7z"/></svg>
          </div>
        </div>
      </div>
    </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Product Info ──────────────────────────────────────── {%- endcomment -%}
  <div class="product-info" itemscope itemtype="https://schema.org/Product">
    <meta itemprop="name" content="{{ current_product.title | escape }}">
    <meta itemprop="description" content="{{ current_product.description | strip_html | truncate: 200 | escape }}">
    <meta itemprop="sku" content="{{ current_product.selected_or_first_available_variant.sku }}">
    {%- if current_product.vendor != blank -%}
      <span itemprop="brand" itemscope itemtype="https://schema.org/Brand" style="display:none;">
        <meta itemprop="name" content="{{ current_product.vendor | escape }}">
      </span>
    {%- endif -%}

    {%- comment -%} Desktop-only: vendor, name, stars, price (hidden on mobile — shown in product-mob-bar above) {%- endcomment -%}
    <div class="product-info__top">
      <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.5rem;">{{ current_product.type | default: current_product.vendor }}</p>

      <h1 class="product-info__name" itemprop="name">{{ current_product.title }}</h1>

      {%- comment -%} Judge.me preview badge — real stars + count, links to the reviews widget; empty until there are reviews {%- endcomment -%}
      <div class="jdgm-widget jdgm-preview-badge" style="margin:0.75rem 0;">{{ current_product.metafields.judgeme.badge }}</div>

      <div class="product-info__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
        <meta itemprop="availability" content="https://schema.org/{% if current_product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}">
        <meta itemprop="priceValidUntil" content="{{ 'now' | date: '%Y' | plus: 1 }}-12-31">
        <meta itemprop="url" content="{{ shop.url }}{{ current_product.url }}">
        <span itemprop="price" content="{{ current_product.selected_or_first_available_variant.price | divided_by: 100.0 }}" data-pdp-price data-price-meta>
          {{ current_product.selected_or_first_available_variant.price | money }}
        </span>
        <span data-pdp-compare>
        {% if current_product.compare_at_price > current_product.price %}
          <s style="font-size:1rem;opacity:0.5;margin-left:8px;">{{ current_product.compare_at_price | money }}</s>
          <span style="font-size:12px;background:var(--color-gold);color:#fff;padding:2px 8px;border-radius:2px;margin-left:6px;font-weight:700;">
            Save {{ current_product.compare_at_price | minus: current_product.price | money }}
          </span>
        {% endif %}
        </span>
      </div>
      <p style="font-size:11px;color:rgba(45,45,45,0.55);margin-top:4px;">GST and shipping calculated at checkout — not included in the price above.</p>
    </div>

    {%- comment -%} Mobile-only: star rating (price is already in product-mob-bar) {%- endcomment -%}
    <div class="product-info__mob-rating" style="margin-bottom:0.75rem;">
      <div class="jdgm-widget jdgm-preview-badge">{{ current_product.metafields.judgeme.badge }}</div>
    </div>

    <div class="product-info__desc" itemprop="description">{{ current_product.description }}</div>

    {%- comment -%} Variant selector — functional buttons wired to the hidden id
      input + price/availability via the inline script below. {%- endcomment -%}
    {% unless current_product.has_only_default_variant %}
      {%- assign sel_variant = current_product.selected_or_first_available_variant -%}
      <div class="pdp-variants" data-pdp-variants>
        {% for option in current_product.options_with_values %}
          {%- assign opt_index = forloop.index0 -%}
          <fieldset class="pdp-variant-group">
            <legend class="pdp-variant-group__label">{{ option.name }}: <span data-pdp-opt-value="{{ opt_index }}">{{ sel_variant.options[opt_index] }}</span></legend>
            <div class="pdp-variant-group__values">
              {% for value in option.values %}
                {%- assign is_sel = false -%}
                {%- if sel_variant.options[opt_index] == value -%}{%- assign is_sel = true -%}{%- endif -%}
                <button type="button" class="pdp-variant{% if is_sel %} is-active{% endif %}"
                  data-pdp-value data-opt-index="{{ opt_index }}" data-value="{{ value | escape }}"
                  aria-pressed="{% if is_sel %}true{% else %}false{% endif %}">
                  {{ value }}
                </button>
              {% endfor %}
            </div>
          </fieldset>
        {% endfor %}
      </div>

      <script type="application/json" data-pdp-variant-data>
        [
        {%- for v in current_product.variants -%}
          {
            "id": {{ v.id }},
            "options": {{ v.options | json }},
            "available": {{ v.available }},
            "price_money": {{ v.price | money | json }},
            "price_cents": {{ v.price }},
            {%- if v.compare_at_price > v.price -%}
              "compare_money": {{ v.compare_at_price | money | json }},
              "save_money": {{ v.compare_at_price | minus: v.price | money | json }},
            {%- else -%}
              "compare_money": "", "save_money": "",
            {%- endif -%}
            {%- if v.featured_image -%}
              "image": {{ v.featured_image | image_url: width: 800 | json }}
            {%- else -%}
              "image": ""
            {%- endif -%}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
        ]
      </script>
    {% endunless %}

    {%- comment -%} Materials / Dimensions table {%- endcomment -%}
    {%- assign mat = current_product.metafields.custom.ingredients_or_materials -%}
    {%- assign dims = current_product.metafields.custom.size_or_dimensions -%}
    {%- assign wt = current_product.metafields.custom.weight -%}
    {%- if mat != blank or dims != blank or wt != blank -%}
    <div style="margin:1.25rem 0;padding:1rem;border:1px solid var(--color-cream-dark);border-radius:2px;background:var(--color-paper);font-size:12px;">
      {%- if mat != blank -%}
      <div style="display:grid;grid-template-columns:120px 1fr;gap:6px;padding-bottom:6px;border-bottom:1px solid var(--color-cream-dark);margin-bottom:6px;">
        <span style="font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-charcoal);">Materials</span>
        <span style="color:rgba(45,45,45,0.75);">{{ mat }}</span>
      </div>
      {%- endif -%}
      {%- if dims != blank -%}
      <div style="display:grid;grid-template-columns:120px 1fr;gap:6px;padding-bottom:6px;border-bottom:1px solid var(--color-cream-dark);margin-bottom:6px;">
        <span style="font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-charcoal);">Dimensions</span>
        <span style="color:rgba(45,45,45,0.75);">{{ dims }}</span>
      </div>
      {%- endif -%}
      {%- if wt != blank -%}
      <div style="display:grid;grid-template-columns:120px 1fr;gap:6px;">
        <span style="font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-charcoal);">Weight</span>
        <span style="color:rgba(45,45,45,0.75);">{{ wt }}</span>
      </div>
      {%- endif -%}
    </div>
    {%- endif -%}

    {%- comment -%} ATC form + Wishlist {%- endcomment -%}
    {% form 'product', current_product, id: 'product-form', novalidate: 'novalidate' %}
      <input type="hidden" name="id" data-variant-select value="{{ current_product.selected_or_first_available_variant.id }}">

      {%- comment -%} Quantity stepper {%- endcomment -%}
      <div class="pdp-qty-row">
        <label class="pdp-qty-label" for="pdp-qty">Quantity</label>
        <div class="pdp-qty" data-pdp-qty>
          <button type="button" class="pdp-qty__btn" data-qty-dec aria-label="Decrease quantity">−</button>
          <input type="number" id="pdp-qty" class="pdp-qty__input" name="quantity" value="1" min="1" inputmode="numeric" aria-label="Quantity">
          <button type="button" class="pdp-qty__btn" data-qty-inc aria-label="Increase quantity">+</button>
        </div>
      </div>

      <div style="display:flex;gap:10px;margin-top:1rem;">
        <button type="submit" class="product-info__atc" data-add-to-cart="{{ current_product.selected_or_first_available_variant.id }}" data-variant-id="{{ current_product.selected_or_first_available_variant.id }}" data-quantity="1" {% unless current_product.available %}disabled{% endunless %} style="flex:1;">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/>
          </svg>
          <span data-atc-label>{% if current_product.available %}Add to Basket{% else %}Sold Out{% endif %}</span>
        </button>
        <button type="button" class="product-wishlist-btn" id="product-wl-btn"
          data-wishlist-btn="{{ current_product.handle }}"
          aria-label="Save to wishlist"
          onclick="vihaWishlistToggle(this,'{{ current_product.handle }}')"
          style="width:52px;flex-shrink:0;border:1px solid var(--color-cream-dark);background:var(--color-paper);color:var(--color-maroon);border-radius:2px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
          </svg>
        </button>
      </div>

      {%- comment -%} Express / accelerated checkout (Shop Pay, GPay, etc.) —
        renders only if dynamic checkout is enabled in Shopify; harmless otherwise. {%- endcomment -%}
      {% if current_product.available %}
        <div class="pdp-buy-now">{{ form | payment_button }}</div>
      {% endif %}
    {% endform %}

    {%- comment -%} Trust signals — honest + client-editable via section settings.
      Nothing fabricated; blank a field in the editor to hide that item. {%- endcomment -%}
    {%- if section.settings.show_trust_row -%}
      {%- assign t1 = section.settings.trust_line_1 -%}
      {%- assign t2 = section.settings.trust_line_2 -%}
      {%- assign t3 = section.settings.trust_line_3 -%}
      {%- if t1 != blank or t2 != blank or t3 != blank -%}
      <ul class="pdp-trust">
        {%- if t1 != blank -%}
        <li class="pdp-trust__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span>{{ t1 }}</span>
        </li>
        {%- endif -%}
        {%- if t2 != blank -%}
        <li class="pdp-trust__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
          <span>{{ t2 }}</span>
        </li>
        {%- endif -%}
        {%- if t3 != blank -%}
        <li class="pdp-trust__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          <span>{{ t3 }}</span>
        </li>
        {%- endif -%}
      </ul>
      {%- endif -%}
    {%- endif -%}


  </div>
</div>

{%- comment -%} ── Sticky Add-to-Cart (mobile) — revealed when the main ATC scrolls out ── {%- endcomment -%}
<div class="pdp-sticky-atc" data-pdp-sticky aria-hidden="true">
  <div class="pdp-sticky-atc__info">
    <img class="pdp-sticky-atc__img" src="{{ current_product.featured_image | img_url: '80x80', crop: 'center' }}" alt="" width="40" height="40" loading="lazy">
    <div class="pdp-sticky-atc__text">
      <span class="pdp-sticky-atc__name">{{ current_product.title | truncate: 40 }}</span>
      <span class="pdp-sticky-atc__price" data-pdp-price>{{ current_product.selected_or_first_available_variant.price | money }}</span>
    </div>
  </div>
  <button type="button" class="product-info__atc pdp-sticky-atc__btn"
    data-add-to-cart="{{ current_product.selected_or_first_available_variant.id }}"
    data-variant-id="{{ current_product.selected_or_first_available_variant.id }}"
    data-quantity="1" {% unless current_product.available %}disabled{% endunless %}>
    <span data-atc-label>{% if current_product.available %}Add to Basket{% else %}Sold Out{% endif %}</span>
  </button>
</div>

{%- comment -%} ── Rich Description Sections ─────────────────────────────── {%- endcomment -%}
{%- assign rich_desc = current_product.metafields.custom.rich_description -%}
{%- if rich_desc != blank -%}
  {%- assign rich_sections = rich_desc -%}
  {%- if rich_sections.size > 0 -%}
  <div style="max-width:var(--max-w);margin:0 auto;padding:4rem 3rem;border-top:1px solid var(--color-cream-dark);">
    <h3 style="font-family:var(--font-heading);font-size:clamp(1.25rem,2.5vw,1.75rem);font-weight:900;color:var(--color-maroon);text-align:center;margin-bottom:2.5rem;">Discover the Mystical Power</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:2.5rem;">
      {%- for section in rich_sections -%}
        <div>
          <h4 style="font-family:var(--font-heading);font-size:1rem;font-weight:600;color:var(--color-maroon);display:flex;align-items:flex-start;gap:8px;margin-bottom:0.75rem;">
            <span style="color:var(--color-gold);margin-top:2px;">•</span> {{ section.title }}
          </h4>
          <p style="font-size:13px;color:rgba(45,45,45,0.8);line-height:1.8;">{{ section.content }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}
{%- endif -%}

{%- comment -%} Video moved into the gallery column above — no separate full-width section needed {%- endcomment -%}

{%- comment -%} ── Customer Reviews — powered by Judge.me ──────────────────
  Real reviews render via the Judge.me app widget below (it also supplies its own
  "Write a Review" form). The star badge near the title uses Judge.me's preview
  badge. No hardcoded/placeholder review data lives in the theme.
{%- endcomment -%}
<section style="max-width:var(--max-w);margin:0 auto;padding:4rem 3rem 5rem;border-top:1px solid var(--color-cream-dark);">
  <div style="text-align:center;margin-bottom:3rem;">
    <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">Real Results</span>
    <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,2rem);font-weight:900;color:var(--color-maroon);">Customer Reviews</h2>
    <div class="section__ornament" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1rem;">
      <div class="section__ornament-line section__ornament-line--left"></div>
      <div class="section__ornament-diamond"></div>
      <div class="section__ornament-line section__ornament-line--right"></div>
    </div>
  </div>

  {%- comment -%}
    Judge.me Review Widget.
    Primary: the Judge.me "Review Widget" APP BLOCK added via Theme Editor
    (Product section → Add block → Apps → Judge.me), captured in templates/product.json.
    Fallback: Judge.me's official manual snippet (renders review data server-side from
    the judgeme metafields), used only if no app block has been added.
  {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == '@app' -%}
        {% render block %}
      {%- endif -%}
    {%- endfor -%}
  {%- else -%}
    <!-- Start of Judge.me code -->{% assign has_legacy = false %}{% if current_product.metafields.judgeme.widget.size > 20 %}{% assign has_legacy = true %}{% endif %}<div style='clear:both'></div><div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ current_product.title | escape }}' data-id='{{ current_product.id }}' data-product-id='{{ current_product.id }}' data-widget='review' data-auto-install='false' data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' data-entry-point='review_widget.js' data-entry-key='review-widget/main.js'>{% if has_legacy %}<div class='jdgm-legacy-widget-content' style='display: none;'>{{ current_product.metafields.judgeme.widget }}</div>{% endif %}</div>{% if current_product.metafields.judgeme.review_widget_data %}<script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ current_product.id }}] = {{ current_product.metafields.judgeme.review_widget_data }}</script>{% endif %}<!-- End of Judge.me code -->
  {%- endif -%}
</section>

<style>
/* Sticky product gallery on desktop */
@media (min-width: 768px) {
  .product-gallery {
    position: sticky;
    top: 5.5rem;
    align-self: start;
  }
}
/* Wishlist btn saved state */
.product-wishlist-btn.is-saved {
  background: var(--color-cream);
  border-color: var(--color-maroon);
  color: var(--color-maroon);
}
.product-wishlist-btn.is-saved svg { fill: currentColor; }
.product-wishlist-btn:hover { background: var(--color-cream); border-color: var(--color-maroon); }
/* Full HTML description from Shopify product body */
.product-info__desc { font-size: 13px; color: rgba(45,45,45,0.80); line-height: 1.8; margin: 0.75rem 0 1.25rem; }
.product-info__desc p { margin-bottom: 0.75rem; }
.product-info__desc ul, .product-info__desc ol { padding-left: 1.25rem; margin-bottom: 0.75rem; }
.product-info__desc li { margin-bottom: 0.35rem; }
.product-info__desc strong, .product-info__desc b { font-weight: 700; color: var(--color-charcoal); }
.product-info__desc a { color: var(--color-maroon); text-decoration: underline; }

/* ── Variant selector ── */
.pdp-variants { margin: 1.25rem 0; }
.pdp-variant-group { border: 0; padding: 0; margin: 0 0 1rem; }
.pdp-variant-group__label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: rgba(45,45,45,0.8); margin-bottom: 8px; padding: 0; }
.pdp-variant-group__label span { color: var(--color-maroon); }
.pdp-variant-group__values { display: flex; flex-wrap: wrap; gap: 8px; }
.pdp-variant {
  padding: 8px 15px; min-height: 40px; border: 1px solid var(--color-cream-dark);
  background: var(--color-paper); font-size: 12px; font-family: inherit; color: var(--color-charcoal);
  border-radius: 2px; cursor: pointer; transition: border-color 0.15s, background 0.15s, color 0.15s;
}
.pdp-variant:hover { border-color: var(--color-maroon); }
.pdp-variant.is-active { border-color: var(--color-maroon); background: var(--color-maroon); color: #fff; }
.pdp-variant.is-unavailable { opacity: 0.4; text-decoration: line-through; }
.pdp-variant:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 2px; }

/* ── Quantity stepper ── */
.pdp-qty-row { display: flex; align-items: center; gap: 14px; margin-top: 1.5rem; }
.pdp-qty-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: rgba(45,45,45,0.8); }
.pdp-qty { display: inline-flex; align-items: center; border: 1px solid var(--color-cream-dark); border-radius: 2px; overflow: hidden; }
.pdp-qty__btn {
  width: 40px; height: 44px; background: var(--color-paper); border: 0; font-size: 18px; line-height: 1;
  color: var(--color-maroon); cursor: pointer; transition: background 0.15s;
}
.pdp-qty__btn:hover { background: var(--color-cream); }
.pdp-qty__btn:focus-visible { outline: 2px solid var(--color-gold); outline-offset: -2px; }
.pdp-qty__input {
  width: 46px; height: 44px; text-align: center; border: 0; border-left: 1px solid var(--color-cream-dark);
  border-right: 1px solid var(--color-cream-dark); font-size: 16px; font-family: inherit; color: var(--color-charcoal);
  background: var(--color-paper); -moz-appearance: textfield;
}
.pdp-qty__input::-webkit-outer-spin-button, .pdp-qty__input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

/* ── Buy Now / express checkout ── */
.pdp-buy-now { margin-top: 10px; }
.pdp-buy-now:empty { display: none; }
.pdp-buy-now .shopify-payment-button__button { min-height: 54px; border-radius: 2px; }

/* ── Trust row ── */
.pdp-trust { list-style: none; margin: 1.5rem 0 0; padding: 1rem 0 0; border-top: 1px solid var(--color-cream-dark); display: flex; flex-direction: column; gap: 10px; }
.pdp-trust__item { display: flex; align-items: center; gap: 10px; font-size: 12px; color: rgba(45,45,45,0.75); }
.pdp-trust__item svg { width: 18px; height: 18px; flex-shrink: 0; color: var(--color-gold); }

/* ── Sticky ATC (mobile only) ── */
.pdp-sticky-atc {
  position: fixed; left: 0; right: 0; bottom: calc(54px + env(safe-area-inset-bottom));
  z-index: 39; display: flex; align-items: center; gap: 12px;
  padding: 8px 12px; background: var(--color-paper); border-top: 1px solid var(--color-cream-dark);
  box-shadow: 0 -4px 16px rgba(0,0,0,0.08);
  transform: translateY(120%); transition: transform 0.25s ease; pointer-events: none;
}
.pdp-sticky-atc.is-visible { transform: translateY(0); pointer-events: auto; }
@media (min-width: 768px) { .pdp-sticky-atc { display: none; } }
.pdp-sticky-atc__info { display: flex; align-items: center; gap: 10px; min-width: 0; flex: 1; }
.pdp-sticky-atc__img { width: 40px; height: 40px; object-fit: contain; mix-blend-mode: multiply; flex-shrink: 0; border: 1px solid var(--color-cream-dark); border-radius: 2px; }
.pdp-sticky-atc__text { display: flex; flex-direction: column; min-width: 0; }
.pdp-sticky-atc__name { font-size: 11px; color: var(--color-charcoal); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.pdp-sticky-atc__price { font-size: 14px; font-weight: 700; color: var(--color-maroon); }
.pdp-sticky-atc__btn { flex: 0 0 auto; width: auto; min-height: 46px; padding: 0 1.25rem; }
@media (prefers-reduced-motion: reduce) { .pdp-sticky-atc { transition: none; } }
</style>

<script>
  (function() {
    var root = document.querySelector('.product-layout');
    if (!root) return;
    var mainImg = document.getElementById('gallery-main-img');

    /* ── Gallery thumb switching ── */
    var thumbs = document.querySelectorAll('[data-gallery-thumb]');
    thumbs.forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (mainImg) mainImg.src = btn.dataset.src;
        thumbs.forEach(function(b) { b.style.opacity = '0.6'; });
        btn.style.opacity = '1';
      });
    });

    var atcButtons = document.querySelectorAll('[data-add-to-cart]');
    var idInput    = document.querySelector('[data-variant-select]');

    /* ── Variant selection ── */
    var dataEl = document.querySelector('[data-pdp-variant-data]');
    var variants = [];
    if (dataEl) { try { variants = JSON.parse(dataEl.textContent); } catch (e) { variants = []; } }
    var groups = Array.prototype.slice.call(document.querySelectorAll('.pdp-variant-group'));

    function selectedValues() {
      return groups.map(function(g) {
        var active = g.querySelector('.pdp-variant.is-active');
        return active ? active.getAttribute('data-value') : null;
      });
    }
    function sameOptions(a, b) {
      if (a.length !== b.length) return false;
      for (var i = 0; i < a.length; i++) { if (a[i] !== b[i]) return false; }
      return true;
    }
    function findVariant(vals) {
      for (var i = 0; i < variants.length; i++) {
        if (sameOptions(variants[i].options, vals)) return variants[i];
      }
      return null;
    }
    function setPrice(v) {
      // v.price_money is server-generated money markup (may include <span class=money>), so use innerHTML.
      document.querySelectorAll('[data-pdp-price]').forEach(function(el) { el.innerHTML = v.price_money; });
      var meta = document.querySelector('[data-price-meta]');
      if (meta) meta.setAttribute('content', (v.price_cents / 100).toFixed(2));
      var compareHtml = '';
      if (v.compare_money) {
        compareHtml = '<s style="opacity:0.5;margin-left:8px;">' + v.compare_money + '</s>' +
          '<span style="font-size:11px;background:var(--color-gold);color:#fff;padding:2px 7px;border-radius:2px;margin-left:6px;font-weight:700;">Save ' + v.save_money + '</span>';
      }
      document.querySelectorAll('[data-pdp-compare]').forEach(function(el) { el.innerHTML = compareHtml; });
    }
    function setAvailability(v) {
      var available = v && v.available;
      atcButtons.forEach(function(btn) {
        btn.disabled = !available;
        var label = btn.querySelector('[data-atc-label]');
        if (label) label.textContent = available ? 'Add to Basket' : (v ? 'Sold Out' : 'Unavailable');
      });
    }
    function markUnavailable(vals) {
      groups.forEach(function(g, gi) {
        g.querySelectorAll('.pdp-variant').forEach(function(btn) {
          var test = vals.slice();
          test[gi] = btn.getAttribute('data-value');
          var exists = variants.some(function(v) {
            if (!v.available) return false;
            for (var i = 0; i < test.length; i++) { if (test[i] !== null && v.options[i] !== test[i]) return false; }
            return true;
          });
          btn.classList.toggle('is-unavailable', !exists);
        });
      });
    }
    function updateSelection() {
      var vals = selectedValues();
      groups.forEach(function(g, gi) {
        var lbl = g.querySelector('[data-pdp-opt-value]');
        if (lbl) lbl.textContent = vals[gi] || '';
      });
      var v = findVariant(vals);
      if (v) {
        atcButtons.forEach(function(btn) {
          btn.setAttribute('data-variant-id', v.id);
          btn.setAttribute('data-add-to-cart', v.id);
        });
        if (idInput) idInput.value = v.id;
        setPrice(v);
        if (v.image && mainImg) mainImg.src = v.image;
      }
      setAvailability(v);
      markUnavailable(vals);
    }

    groups.forEach(function(g) {
      g.querySelectorAll('.pdp-variant').forEach(function(btn) {
        btn.addEventListener('click', function() {
          g.querySelectorAll('.pdp-variant').forEach(function(b) {
            b.classList.remove('is-active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('is-active');
          btn.setAttribute('aria-pressed', 'true');
          updateSelection();
        });
      });
    });
    if (groups.length) markUnavailable(selectedValues());

    /* ── Quantity stepper ── */
    var qtyInput = document.getElementById('pdp-qty');
    var qtyWrap  = document.querySelector('[data-pdp-qty]');
    function syncQty() {
      var q = Math.max(1, parseInt(qtyInput.value, 10) || 1);
      qtyInput.value = q;
      atcButtons.forEach(function(btn) { btn.setAttribute('data-quantity', q); });
    }
    if (qtyInput && qtyWrap) {
      qtyWrap.querySelector('[data-qty-dec]').addEventListener('click', function() {
        qtyInput.value = Math.max(1, (parseInt(qtyInput.value, 10) || 1) - 1); syncQty();
      });
      qtyWrap.querySelector('[data-qty-inc]').addEventListener('click', function() {
        qtyInput.value = (parseInt(qtyInput.value, 10) || 1) + 1; syncQty();
      });
      qtyInput.addEventListener('change', syncQty);
    }

    /* ── Sticky ATC reveal (mobile) ── */
    var sticky   = document.querySelector('[data-pdp-sticky]');
    var mainAtc  = document.querySelector('.product-info .product-info__atc');
    if (sticky && mainAtc && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries) {
        var e = entries[0];
        var scrolledPast = !e.isIntersecting && e.boundingClientRect.top < 0;
        sticky.classList.toggle('is-visible', scrolledPast);
        sticky.setAttribute('aria-hidden', scrolledPast ? 'false' : 'true');
      }, { threshold: 0 });
      io.observe(mainAtc);
    }
  })();
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "header", "content": "Trust signals (below Add to Cart)" },
    { "type": "checkbox", "id": "show_trust_row", "label": "Show trust row", "default": true },
    { "type": "text", "id": "trust_line_1", "label": "Trust line 1", "info": "Leave blank to hide. Keep claims truthful.", "default": "Secure checkout — SSL encrypted" },
    { "type": "text", "id": "trust_line_2", "label": "Trust line 2", "info": "Leave blank to hide.", "default": "Ships across India" },
    { "type": "text", "id": "trust_line_3", "label": "Trust line 3", "info": "Leave blank to hide.", "default": "Genuine products, carefully packed" }
  ],
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
