<div class="hero">
  {% if section.settings.bg_image != blank %}
    {%- assign hero_bg = section.settings.bg_image | image_url: width: 1800 -%}
    <link rel="preload" as="image" href="{{ hero_bg }}" fetchpriority="high">
    <div class="hero__bg" aria-hidden="true" style="background-image:url({{ hero_bg }});"></div>
  {% endif %}
  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__content container">
    {% if section.settings.eyebrow != blank %}
      <span class="hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}

    <h1 class="hero__heading">{{ section.settings.heading | default: 'Heritage Meets Beauty' }}</h1>

    {% if section.settings.subtext != blank %}
      <p class="hero__subtext">{{ section.settings.subtext }}</p>
    {% endif %}

    <div class="hero__actions">
      {% if section.settings.cta_primary_label != blank %}
        <a href="{{ section.settings.cta_primary_url | default: '/collections/all' }}" class="btn btn--primary">
          {{ section.settings.cta_primary_label }}
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      {% endif %}
      {% if section.settings.cta_secondary_label != blank %}
        <a href="{{ section.settings.cta_secondary_url | default: '/pages/our-story' }}" class="btn btn--outline">
          {{ section.settings.cta_secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "bg_image",           "label": "Background image" },
    { "type": "text",         "id": "eyebrow",            "label": "Eyebrow text",       "default": "Rooted in Ayurveda · Crafted with Love" },
    { "type": "text",         "id": "heading",            "label": "Heading",            "default": "Ancient Wisdom\nfor Modern Beauty" },
    { "type": "textarea",     "id": "subtext",            "label": "Subtext",            "default": "Viha Heritage brings you pure, time-tested Ayurvedic formulations from the heart of India — trusted by thousands for glowing skin, lustrous hair, and holistic wellness." },
    { "type": "text",         "id": "cta_primary_label",  "label": "Primary CTA text",   "default": "Shop All Products" },
    { "type": "url",          "id": "cta_primary_url",    "label": "Primary CTA link" },
    { "type": "text",         "id": "cta_secondary_label","label": "Secondary CTA text", "default": "Our Heritage Story" },
    { "type": "url",          "id": "cta_secondary_url",  "label": "Secondary CTA link" }
  ],
  "presets": [
    { "name": "Hero Banner", "category": "Promotional" }
  ]
}
{% endschema %}
